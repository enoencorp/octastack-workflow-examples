        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Memcached inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/memcached-inventory.ini <<'INVENTORY'\n[memcached]\n10.31.120.11 role=cache name=memcached-01\n10.31.120.12 role=cache name=memcached-02\n10.31.120.13 role=cache name=memcached-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install Memcached container runtime",
            "command": "set -euo pipefail\ncat >/tmp/memcached-runtime.yml <<'PLAYBOOK'\n- hosts: memcached\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/memcached-inventory.ini /tmp/memcached-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render Memcached cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/memcached-deploy.yml <<'PLAYBOOK'\n- hosts: memcached\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/memcached\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/memcached/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            memcached:\n              image: memcached:1.6\n              container_name: octastack-memcached\n              restart: unless-stopped\n              command: \"memcached -m 256\"\n              ports:\n                - \"11211:11211\"\n              volumes:\n                - data:/tmp\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy Memcached cluster",
            "command": "set -euo pipefail\ncat >>/tmp/memcached-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/memcached/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/memcached/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/memcached/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/memcached-inventory.ini /tmp/memcached-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document Memcached topology",
            "command": "set -euo pipefail\ncat >/tmp/memcached-topology.md <<'EOF'\n# Memcached HA topology\n\nMembers:\n- memcached-01: 10.31.120.11 (cache)\n- memcached-02: 10.31.120.12 (cache)\n- memcached-03: 10.31.120.13 (cache)\n\nThis example deploys one Memcached container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/memcached-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate Memcached cluster",
            "command": "set -euo pipefail\nansible -i /tmp/memcached-inventory.ini memcached -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
