          "position": {
            "x": 1740,
            "y": 7430
          },
          "data": {
            "label": "Memcached HA health check",
            "command": "docker exec octastack-memcached sh -lc 'echo version | nc 127.0.0.1 11211 || true'",
            "sudo": false
          }
        },
