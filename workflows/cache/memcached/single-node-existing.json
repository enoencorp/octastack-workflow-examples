          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Memcached runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Memcached directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/memcached\ninstall -d -m 0750 /var/lib/octastack/memcached\ncat >/opt/octastack/memcached/.env <<'EOF'\nOCTASTACK_SERVICE=Memcached\nEOF\nchmod 0600 /opt/octastack/memcached/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Memcached compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/memcached/compose.yml <<'COMPOSE'\nservices:\n  memcached:\n    image: memcached:1.6\n    container_name: octastack-memcached\n    restart: unless-stopped\n    command: \"memcached -m 256\"\n    ports:\n      - \"11211:11211\"\n    volumes:\n      - data:/tmp\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Memcached",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/memcached/compose.yml pull\ndocker compose -f /opt/octastack/memcached/compose.yml up -d\ndocker compose -f /opt/octastack/memcached/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Memcached",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-memcached\ndocker logs octastack-memcached --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Memcached health check",
            "command": "docker exec octastack-memcached sh -lc 'echo version | nc 127.0.0.1 11211 || true'",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 4730
          },
          "data": {
            "label": "End"
          }
