        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1943,
            "y": 3600
          },
          "data": {
            "label": "Prepare Valkey Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1943,
            "y": 4005
          },
          "data": {
            "label": "Render Valkey Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[valkey_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.66.11 10.0.66.12 10.0.66.13 10.0.66.14 10.0.66.15 10.0.66.16 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.66.11) NODE_NAME='valkey-01'; NODE_ROLE='cache'; NODE_INDEX=1 ;;\n  10.0.66.12) NODE_NAME='valkey-02'; NODE_ROLE='cache'; NODE_INDEX=2 ;;\n  10.0.66.13) NODE_NAME='valkey-03'; NODE_ROLE='cache'; NODE_INDEX=3 ;;\n  10.0.66.14) NODE_NAME='valkey-04'; NODE_ROLE='cache'; NODE_INDEX=4 ;;\n  10.0.66.15) NODE_NAME='valkey-05'; NODE_ROLE='cache'; NODE_INDEX=5 ;;\n  10.0.66.16) NODE_NAME='valkey-06'; NODE_ROLE='cache'; NODE_INDEX=6 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/valkey_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/valkey_cluster_ha\ncat >/opt/octastack/valkey_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=Valkey\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.66.11\nCLUSTER_PEERS=10.0.66.11,10.0.66.12,10.0.66.13,10.0.66.14,10.0.66.15,10.0.66.16\nSEED_IPS=10.0.66.11,10.0.66.12,10.0.66.13\n\nEOF\nchmod 0600 /opt/octastack/valkey_cluster_ha/.env\n\ncat >/opt/octastack/valkey_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  valkey:\n    image: valkey/valkey:8\n    container_name: octastack-valkey\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      valkey-server --bind 0.0.0.0 --protected-mode no --appendonly yes --cluster-enabled yes --cluster-config-file nodes.conf --cluster-node-timeout 5000 --cluster-announce-ip ${CURRENT_IP}\n    volumes:\n      - data:/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1943,
            "y": 4410
          },
          "data": {
            "label": "Deploy Valkey Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[valkey_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/valkey_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/valkey_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/valkey_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1943,
            "y": 4815
          },
          "data": {
            "label": "Initialize Valkey Cluster HA node",
            "command": "set -euo pipefail\n\nlog() { printf '[valkey-cluster-ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.66.11 10.0.66.12 10.0.66.13 10.0.66.14 10.0.66.15 10.0.66.16 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.66.11) NODE_NAME='valkey-01'; NODE_ROLE='cache'; NODE_INDEX=1 ;;\n  10.0.66.12) NODE_NAME='valkey-02'; NODE_ROLE='cache'; NODE_INDEX=2 ;;\n  10.0.66.13) NODE_NAME='valkey-03'; NODE_ROLE='cache'; NODE_INDEX=3 ;;\n  10.0.66.14) NODE_NAME='valkey-04'; NODE_ROLE='cache'; NODE_INDEX=4 ;;\n  10.0.66.15) NODE_NAME='valkey-05'; NODE_ROLE='cache'; NODE_INDEX=5 ;;\n  10.0.66.16) NODE_NAME='valkey-06'; NODE_ROLE='cache'; NODE_INDEX=6 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ncontainer_ready=0\nfor attempt in $(seq 1 60); do\n  if docker exec octastack-valkey sh -lc \"valkey-cli ping\" >/dev/null 2>&1; then\n    container_ready=1\n    break\n  fi\n  sleep 5\ndone\nif [ \"$container_ready\" = \"1\" ]; then\n  log \"container octastack-valkey is ready\"\nelse\ndocker logs octastack-valkey --tail=120 || true\necho \"container octastack-valkey did not become ready\" >&2\nexit 1\nfi\n\nif [ \"$NODE_INDEX\" = \"1\" ]; then\n  sleep 15\n  docker exec octastack-valkey valkey-cli --cluster create 10.0.66.11:6379 10.0.66.12:6379 10.0.66.13:6379 10.0.66.14:6379 10.0.66.15:6379 10.0.66.16:6379 --cluster-replicas 1 --cluster-yes || true\nfi\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1943,
            "y": 5220
          },
          "data": {
            "label": "Document Valkey Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/valkey_cluster_ha-topology.md <<'EOF'\n# Valkey Cluster HA\n\nMembers:\n- valkey-01: 10.0.66.11 (cache)\n- valkey-02: 10.0.66.12 (cache)\n- valkey-03: 10.0.66.13 (cache)\n- valkey-04: 10.0.66.14 (cache)\n- valkey-05: 10.0.66.15 (cache)\n- valkey-06: 10.0.66.16 (cache)\n\nSix Valkey members run native cluster mode as three primaries plus three replicas with generated cluster announce IPs.\nEOF\ncat /tmp/valkey_cluster_ha-topology.md\n",
            "sudo": true
          }
        },
