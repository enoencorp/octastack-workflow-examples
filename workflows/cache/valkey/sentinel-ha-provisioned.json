        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Valkey Sentinel HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Render Valkey Sentinel HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[valkey_sentinel_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.66.11 10.0.66.12 10.0.66.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.66.11) NODE_NAME='valkey-01'; NODE_ROLE='cache'; NODE_INDEX=1 ;;\n  10.0.66.12) NODE_NAME='valkey-02'; NODE_ROLE='cache'; NODE_INDEX=2 ;;\n  10.0.66.13) NODE_NAME='valkey-03'; NODE_ROLE='cache'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nif [ \"$NODE_INDEX\" = \"1\" ]; then\n  REPLICAOF_LINE=\"\"\nelse\n  REPLICAOF_LINE=\"replicaof ${FIRST_NODE_IP} 6379\"\nfi\n\ninstall -d -m 0750 /opt/octastack/valkey_sentinel_ha\ninstall -d -m 0750 /var/lib/octastack/valkey_sentinel_ha\ncat >/opt/octastack/valkey_sentinel_ha/.env <<EOF\nOCTASTACK_SERVICE=Valkey\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.66.11\nCLUSTER_PEERS=10.0.66.11,10.0.66.12,10.0.66.13\nSEED_IPS=10.0.66.11,10.0.66.12,10.0.66.13\n\nEOF\nchmod 0600 /opt/octastack/valkey_sentinel_ha/.env\n\ncat >/opt/octastack/valkey_sentinel_ha/valkey.conf <<EOF\nbind 0.0.0.0\nprotected-mode no\nappendonly yes\ndir /data\n${REPLICAOF_LINE}\nEOF\ncat >/opt/octastack/valkey_sentinel_ha/sentinel.conf <<EOF\nport 26379\nsentinel monitor valkey-ha ${FIRST_NODE_IP} 6379 2\nsentinel down-after-milliseconds valkey-ha 5000\nsentinel failover-timeout valkey-ha 60000\nsentinel parallel-syncs valkey-ha 1\nEOF\n\ncat >/opt/octastack/valkey_sentinel_ha/compose.yml <<'COMPOSE'\nservices:\n  valkey:\n    image: valkey/valkey:8\n    container_name: octastack-valkey\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      sh -lc 'valkey-server /etc/valkey/valkey.conf & exec valkey-server /etc/valkey/sentinel.conf --sentinel'\n    volumes:\n      - data:/data\n      - /opt/octastack/valkey_sentinel_ha/valkey.conf:/etc/valkey/valkey.conf:ro\n      - /opt/octastack/valkey_sentinel_ha/sentinel.conf:/etc/valkey/sentinel.conf:ro\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Deploy Valkey Sentinel HA node",
            "command": "set -euo pipefail\nlog() { printf '[valkey_sentinel_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/valkey_sentinel_ha/compose.yml pull\ndocker compose -f /opt/octastack/valkey_sentinel_ha/compose.yml up -d\ndocker compose -f /opt/octastack/valkey_sentinel_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Document Valkey Sentinel HA topology",
            "command": "set -euo pipefail\ncat >/tmp/valkey_sentinel_ha-topology.md <<'EOF'\n# Valkey Sentinel HA\n\nMembers:\n- valkey-01: 10.0.66.11 (cache)\n- valkey-02: 10.0.66.12 (cache)\n- valkey-03: 10.0.66.13 (cache)\n\nThree Valkey members run primary/replica data nodes plus Sentinel quorum on every member.\nEOF\ncat /tmp/valkey_sentinel_ha-topology.md\n",
            "sudo": true
          }
        },
