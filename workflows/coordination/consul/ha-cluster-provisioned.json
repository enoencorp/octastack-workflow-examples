        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Consul inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/consul-inventory.ini <<'INVENTORY'\n[consul]\n10.31.98.11 role=consul name=consul-01\n10.31.98.12 role=consul name=consul-02\n10.31.98.13 role=consul name=consul-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install Consul container runtime",
            "command": "set -euo pipefail\ncat >/tmp/consul-runtime.yml <<'PLAYBOOK'\n- hosts: consul\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/consul-inventory.ini /tmp/consul-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render Consul cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/consul-deploy.yml <<'PLAYBOOK'\n- hosts: consul\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/consul\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/consul/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            consul:\n              image: hashicorp/consul:1.19\n              container_name: octastack-consul\n              restart: unless-stopped\n              command: \"agent -server -bootstrap-expect=1 -ui -client=0.0.0.0\"\n              ports:\n                - \"8500:8500\"\n                - \"8600:8600/udp\"\n              volumes:\n                - data:/consul/data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy Consul cluster",
            "command": "set -euo pipefail\ncat >>/tmp/consul-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/consul/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/consul/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/consul/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/consul-inventory.ini /tmp/consul-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document Consul topology",
            "command": "set -euo pipefail\ncat >/tmp/consul-topology.md <<'EOF'\n# Consul HA topology\n\nMembers:\n- consul-01: 10.31.98.11 (consul)\n- consul-02: 10.31.98.12 (consul)\n- consul-03: 10.31.98.13 (consul)\n\nThis example deploys one Consul container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/consul-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate Consul cluster",
            "command": "set -euo pipefail\nansible -i /tmp/consul-inventory.ini consul -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
