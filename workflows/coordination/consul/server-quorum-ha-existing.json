        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 3600
          },
          "data": {
            "label": "Prepare Consul Server Quorum HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4005
          },
          "data": {
            "label": "Render Consul Server Quorum HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[consul_server_quorum_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.161.11 10.0.161.12 10.0.161.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.161.11) NODE_NAME='consul-01'; NODE_ROLE='consul'; NODE_INDEX=1 ;;\n  10.0.161.12) NODE_NAME='consul-02'; NODE_ROLE='consul'; NODE_INDEX=2 ;;\n  10.0.161.13) NODE_NAME='consul-03'; NODE_ROLE='consul'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/consul_server_quorum_ha\ninstall -d -m 0750 /var/lib/octastack/consul_server_quorum_ha\ncat >/opt/octastack/consul_server_quorum_ha/.env <<EOF\nOCTASTACK_SERVICE=Consul\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.161.11\nCLUSTER_PEERS=10.0.161.11,10.0.161.12,10.0.161.13\nSEED_IPS=10.0.161.11,10.0.161.12,10.0.161.13\n\nEOF\nchmod 0600 /opt/octastack/consul_server_quorum_ha/.env\n\ncat >/opt/octastack/consul_server_quorum_ha/compose.yml <<'COMPOSE'\nservices:\n  consul:\n    image: hashicorp/consul:1.19\n    container_name: octastack-consul\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      agent -server -bootstrap-expect=3 -node=${OCTASTACK_NODE_NAME} -bind=${CURRENT_IP} -client=0.0.0.0 -retry-join=10.0.161.11 -retry-join=10.0.161.12 -retry-join=10.0.161.13 -ui\n    volumes:\n      - data:/consul/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4410
          },
          "data": {
            "label": "Deploy Consul Server Quorum HA node",
            "command": "set -euo pipefail\nlog() { printf '[consul_server_quorum_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/consul_server_quorum_ha/compose.yml pull\ndocker compose -f /opt/octastack/consul_server_quorum_ha/compose.yml up -d\ndocker compose -f /opt/octastack/consul_server_quorum_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4815
          },
          "data": {
            "label": "Document Consul Server Quorum HA topology",
            "command": "set -euo pipefail\ncat >/tmp/consul_server_quorum_ha-topology.md <<'EOF'\n# Consul Server Quorum HA\n\nMembers:\n- consul-01: 10.0.161.11 (consul)\n- consul-02: 10.0.161.12 (consul)\n- consul-03: 10.0.161.13 (consul)\n\nThree Consul server members form a Raft quorum and expose the UI/client API on every member.\nEOF\ncat /tmp/consul_server_quorum_ha-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 5220
          },
          "data": {
            "label": "Validate Consul Server Quorum HA node",
            "command": "docker exec octastack-consul consul operator raft list-peers || true\n",
            "sudo": true
          }
        },
