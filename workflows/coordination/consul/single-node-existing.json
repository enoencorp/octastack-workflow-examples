          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Consul runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Consul directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/consul\ninstall -d -m 0750 /var/lib/octastack/consul\ncat >/opt/octastack/consul/.env <<'EOF'\nOCTASTACK_SERVICE=Consul\nEOF\nchmod 0600 /opt/octastack/consul/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Consul compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/consul/compose.yml <<'COMPOSE'\nservices:\n  consul:\n    image: hashicorp/consul:1.19\n    container_name: octastack-consul\n    restart: unless-stopped\n    command: \"agent -server -bootstrap-expect=1 -ui -client=0.0.0.0\"\n    ports:\n      - \"8500:8500\"\n      - \"8600:8600/udp\"\n    volumes:\n      - data:/consul/data\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Consul",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/consul/compose.yml pull\ndocker compose -f /opt/octastack/consul/compose.yml up -d\ndocker compose -f /opt/octastack/consul/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Consul",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-consul\ndocker logs octastack-consul --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Consul health check",
            "command": "curl -fsS http://127.0.0.1:8500/v1/status/leader",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 4730
          },
          "data": {
            "label": "End"
          }
        }
