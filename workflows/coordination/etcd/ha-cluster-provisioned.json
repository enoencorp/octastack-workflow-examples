        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare etcd inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/etcd-inventory.ini <<'INVENTORY'\n[etcd]\n10.31.97.11 role=etcd name=etcd-01\n10.31.97.12 role=etcd name=etcd-02\n10.31.97.13 role=etcd name=etcd-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install etcd container runtime",
            "command": "set -euo pipefail\ncat >/tmp/etcd-runtime.yml <<'PLAYBOOK'\n- hosts: etcd\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/etcd-inventory.ini /tmp/etcd-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render etcd cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/etcd-deploy.yml <<'PLAYBOOK'\n- hosts: etcd\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/etcd\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/etcd/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            etcd:\n              image: quay.io/coreos/etcd:v3.5.16\n              container_name: octastack-etcd\n              restart: unless-stopped\n              command: \"etcd --advertise-client-urls=http://0.0.0.0:2379 --listen-client-urls=http://0.0.0.0:2379\"\n              ports:\n                - \"2379:2379\"\n                - \"2380:2380\"\n              volumes:\n                - data:/etcd-data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy etcd cluster",
            "command": "set -euo pipefail\ncat >>/tmp/etcd-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/etcd/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/etcd/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/etcd/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/etcd-inventory.ini /tmp/etcd-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document etcd topology",
            "command": "set -euo pipefail\ncat >/tmp/etcd-topology.md <<'EOF'\n# etcd HA topology\n\nMembers:\n- etcd-01: 10.31.97.11 (etcd)\n- etcd-02: 10.31.97.12 (etcd)\n- etcd-03: 10.31.97.13 (etcd)\n\nThis example deploys one etcd container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/etcd-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate etcd cluster",
            "command": "set -euo pipefail\nansible -i /tmp/etcd-inventory.ini etcd -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
