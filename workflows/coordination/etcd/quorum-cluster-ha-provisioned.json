        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare etcd Quorum Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Render etcd Quorum Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[etcd_quorum_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.160.11 10.0.160.12 10.0.160.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.160.11) NODE_NAME='etcd-01'; NODE_ROLE='etcd'; NODE_INDEX=1 ;;\n  10.0.160.12) NODE_NAME='etcd-02'; NODE_ROLE='etcd'; NODE_INDEX=2 ;;\n  10.0.160.13) NODE_NAME='etcd-03'; NODE_ROLE='etcd'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/etcd_quorum_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/etcd_quorum_cluster_ha\ncat >/opt/octastack/etcd_quorum_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=etcd\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.160.11\nCLUSTER_PEERS=10.0.160.11,10.0.160.12,10.0.160.13\nSEED_IPS=10.0.160.11,10.0.160.12,10.0.160.13\nETCD_INITIAL_CLUSTER=etcd-01=http://10.0.160.11:2380,etcd-02=http://10.0.160.12:2380,etcd-03=http://10.0.160.13:2380\nEOF\nchmod 0600 /opt/octastack/etcd_quorum_cluster_ha/.env\n\ncat >/opt/octastack/etcd_quorum_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  etcd:\n    image: quay.io/coreos/etcd:v3.5.16\n    container_name: octastack-etcd\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      etcd\n      --name=${OCTASTACK_NODE_NAME}\n      --data-dir=/etcd-data\n      --listen-peer-urls=http://0.0.0.0:2380\n      --listen-client-urls=http://0.0.0.0:2379\n      --initial-advertise-peer-urls=http://${CURRENT_IP}:2380\n      --advertise-client-urls=http://${CURRENT_IP}:2379\n      --initial-cluster=${ETCD_INITIAL_CLUSTER}\n      --initial-cluster-state=new\n    volumes:\n      - data:/etcd-data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Deploy etcd Quorum Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[etcd_quorum_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/etcd_quorum_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/etcd_quorum_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/etcd_quorum_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Document etcd Quorum Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/etcd_quorum_cluster_ha-topology.md <<'EOF'\n# etcd Quorum Cluster HA\n\nMembers:\n- etcd-01: 10.0.160.11 (etcd)\n- etcd-02: 10.0.160.12 (etcd)\n- etcd-03: 10.0.160.13 (etcd)\n\nThree etcd members form an odd-number quorum with generated peer and client advertise URLs.\nEOF\ncat /tmp/etcd_quorum_cluster_ha-topology.md\n",
            "sudo": true
          }
        },
