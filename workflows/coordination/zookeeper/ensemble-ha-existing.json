        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 3600
          },
          "data": {
            "label": "Prepare ZooKeeper Ensemble HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4005
          },
          "data": {
            "label": "Render ZooKeeper Ensemble HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[zookeeper_ensemble_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.162.11 10.0.162.12 10.0.162.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.162.11) NODE_NAME='zookeeper-01'; NODE_ROLE='zookeeper'; NODE_INDEX=1 ;;\n  10.0.162.12) NODE_NAME='zookeeper-02'; NODE_ROLE='zookeeper'; NODE_INDEX=2 ;;\n  10.0.162.13) NODE_NAME='zookeeper-03'; NODE_ROLE='zookeeper'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nZOO_MY_ID=$NODE_INDEX\ninstall -d -m 0750 /opt/octastack/zookeeper_ensemble_ha\ninstall -d -m 0750 /var/lib/octastack/zookeeper_ensemble_ha\ncat >/opt/octastack/zookeeper_ensemble_ha/.env <<EOF\nOCTASTACK_SERVICE=ZooKeeper\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.162.11\nCLUSTER_PEERS=10.0.162.11,10.0.162.12,10.0.162.13\nSEED_IPS=10.0.162.11,10.0.162.12,10.0.162.13\nZOO_MY_ID=$ZOO_MY_ID\nZOO_SERVERS=server.1=10.0.162.11:2888:3888;2181 server.2=10.0.162.12:2888:3888;2181 server.3=10.0.162.13:2888:3888;2181\nEOF\nchmod 0600 /opt/octastack/zookeeper_ensemble_ha/.env\n\ncat >/opt/octastack/zookeeper_ensemble_ha/compose.yml <<'COMPOSE'\nservices:\n  zookeeper:\n    image: zookeeper:3.9\n    container_name: octastack-zookeeper\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    environment:\n      ZOO_MY_ID: \"${ZOO_MY_ID}\"\n      ZOO_SERVERS: \"${ZOO_SERVERS}\"\n      ZOO_4LW_COMMANDS_WHITELIST: \"ruok,stat,srvr,mntr\"\n    volumes:\n      - data:/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 885,
