        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare ArangoDB inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/arangodb-inventory.ini <<'INVENTORY'\n[arangodb]\n10.31.118.11 role=arangodb name=arangodb-01\n10.31.118.12 role=arangodb name=arangodb-02\n10.31.118.13 role=arangodb name=arangodb-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install ArangoDB container runtime",
            "command": "set -euo pipefail\ncat >/tmp/arangodb-runtime.yml <<'PLAYBOOK'\n- hosts: arangodb\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/arangodb-inventory.ini /tmp/arangodb-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render ArangoDB cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/arangodb-deploy.yml <<'PLAYBOOK'\n- hosts: arangodb\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/arangodb\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/arangodb/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            arangodb:\n              image: arangodb:3.12\n              container_name: octastack-arangodb\n              restart: unless-stopped\n              environment:\n                ARANGO_ROOT_PASSWORD: \"change-me\"\n              ports:\n                - \"8529:8529\"\n              volumes:\n                - data:/var/lib/arangodb3\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy ArangoDB cluster",
            "command": "set -euo pipefail\ncat >>/tmp/arangodb-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/arangodb/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/arangodb/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/arangodb/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/arangodb-inventory.ini /tmp/arangodb-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document ArangoDB topology",
            "command": "set -euo pipefail\ncat >/tmp/arangodb-topology.md <<'EOF'\n# ArangoDB HA topology\n\nMembers:\n- arangodb-01: 10.31.118.11 (arangodb)\n- arangodb-02: 10.31.118.12 (arangodb)\n- arangodb-03: 10.31.118.13 (arangodb)\n\nThis example deploys one ArangoDB container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/arangodb-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate ArangoDB cluster",
            "command": "set -euo pipefail\nansible -i /tmp/arangodb-inventory.ini arangodb -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
