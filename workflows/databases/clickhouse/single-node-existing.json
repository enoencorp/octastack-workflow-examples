        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare ClickHouse runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create ClickHouse directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/clickhouse\ninstall -d -m 0750 /var/lib/octastack/clickhouse\ncat >/opt/octastack/clickhouse/.env <<'EOF'\nCLICKHOUSE_DB=app_db\nCLICKHOUSE_USER=app_user\nCLICKHOUSE_PASSWORD=change-me\nEOF\nchmod 0600 /opt/octastack/clickhouse/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render ClickHouse compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/clickhouse/compose.yml <<'COMPOSE'\nservices:\n  clickhouse:\n    image: clickhouse/clickhouse-server:24.8\n    container_name: octastack-clickhouse\n    restart: unless-stopped\n    environment:\n      CLICKHOUSE_DB: \"app_db\"\n      CLICKHOUSE_USER: \"app_user\"\n      CLICKHOUSE_PASSWORD: \"change-me\"\n    ports:\n      - \"8123:8123\"\n      - \"9000:9000\"\n    volumes:\n      - data:/var/lib/clickhouse\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy ClickHouse",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/clickhouse/compose.yml pull\ndocker compose -f /opt/octastack/clickhouse/compose.yml up -d\ndocker compose -f /opt/octastack/clickhouse/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect ClickHouse",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-clickhouse\ndocker logs octastack-clickhouse --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "ClickHouse health check",
            "command": "curl -fsS 'http://127.0.0.1:8123/ping'",
            "sudo": false
          }
        },
        {
