        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare CockroachDB inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/cockroachdb-inventory.ini <<'INVENTORY'\n[cockroachdb]\n10.31.87.11 role=cockroach name=cockroachdb-01\n10.31.87.12 role=cockroach name=cockroachdb-02\n10.31.87.13 role=cockroach name=cockroachdb-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install CockroachDB container runtime",
            "command": "set -euo pipefail\ncat >/tmp/cockroachdb-runtime.yml <<'PLAYBOOK'\n- hosts: cockroachdb\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/cockroachdb-inventory.ini /tmp/cockroachdb-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render CockroachDB cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/cockroachdb-deploy.yml <<'PLAYBOOK'\n- hosts: cockroachdb\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/cockroachdb\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/cockroachdb/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            cockroachdb:\n              image: cockroachdb/cockroach:v24.2.0\n              container_name: octastack-cockroachdb\n              restart: unless-stopped\n              command: \"start-single-node --insecure --store=/cockroach/cockroach-data\"\n              ports:\n                - \"26257:26257\"\n                - \"8080:8080\"\n              volumes:\n                - data:/cockroach/cockroach-data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy CockroachDB cluster",
            "command": "set -euo pipefail\ncat >>/tmp/cockroachdb-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/cockroachdb/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/cockroachdb/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/cockroachdb/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/cockroachdb-inventory.ini /tmp/cockroachdb-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document CockroachDB topology",
            "command": "set -euo pipefail\ncat >/tmp/cockroachdb-topology.md <<'EOF'\n# CockroachDB HA topology\n\nMembers:\n- cockroachdb-01: 10.31.87.11 (cockroach)\n- cockroachdb-02: 10.31.87.12 (cockroach)\n- cockroachdb-03: 10.31.87.13 (cockroach)\n\nThis example deploys one CockroachDB container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/cockroachdb-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate CockroachDB cluster",
            "command": "set -euo pipefail\nansible -i /tmp/cockroachdb-inventory.ini cockroachdb -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7430
          },
          "data": {
            "label": "CockroachDB HA health check",
            "command": "docker exec octastack-cockroachdb cockroach sql --insecure --execute='select 1'",
            "sudo": false
          }
        },
