          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for automation runner",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare CouchDB inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/couchdb-inventory.ini <<'INVENTORY'\n[couchdb]\n10.31.90.11 role=couchdb name=couchdb-01\n10.31.90.12 role=couchdb name=couchdb-02\n10.31.90.13 role=couchdb name=couchdb-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Install CouchDB container runtime",
            "command": "set -euo pipefail\ncat >/tmp/couchdb-runtime.yml <<'PLAYBOOK'\n- hosts: couchdb\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/couchdb-inventory.ini /tmp/couchdb-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render CouchDB cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/couchdb-deploy.yml <<'PLAYBOOK'\n- hosts: couchdb\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/couchdb\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/couchdb/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            couchdb:\n              image: couchdb:3\n              container_name: octastack-couchdb\n              restart: unless-stopped\n              environment:\n                COUCHDB_USER: \"admin\"\n                COUCHDB_PASSWORD: \"change-me\"\n              ports:\n                - \"5984:5984\"\n              volumes:\n                - data:/opt/couchdb/data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy CouchDB cluster",
            "command": "set -euo pipefail\ncat >>/tmp/couchdb-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/couchdb/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/couchdb/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/couchdb/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/couchdb-inventory.ini /tmp/couchdb-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Document CouchDB topology",
            "command": "set -euo pipefail\ncat >/tmp/couchdb-topology.md <<'EOF'\n# CouchDB HA topology\n\nMembers:\n- couchdb-01: 10.31.90.11 (couchdb)\n- couchdb-02: 10.31.90.12 (couchdb)\n- couchdb-03: 10.31.90.13 (couchdb)\n\nThis example deploys one CouchDB container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/couchdb-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Validate CouchDB cluster",
            "command": "set -euo pipefail\nansible -i /tmp/couchdb-inventory.ini couchdb -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 5000
          },
          "data": {
            "label": "CouchDB HA health check",
            "command": "curl -fsS http://admin:change-me@127.0.0.1:5984/_up",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
