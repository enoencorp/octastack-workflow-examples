        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare CouchDB Native Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Render CouchDB Native Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[couchdb_native_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.11.11 10.0.11.12 10.0.11.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.11.11) NODE_NAME='couchdb-01'; NODE_ROLE='couchdb'; NODE_INDEX=1 ;;\n  10.0.11.12) NODE_NAME='couchdb-02'; NODE_ROLE='couchdb'; NODE_INDEX=2 ;;\n  10.0.11.13) NODE_NAME='couchdb-03'; NODE_ROLE='couchdb'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/couchdb_native_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/couchdb_native_cluster_ha\ncat >/opt/octastack/couchdb_native_cluster_ha/.env <<EOF\nCOUCHDB_USER=admin\nCOUCHDB_PASSWORD=change-me\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.11.11\nCLUSTER_PEERS=10.0.11.11,10.0.11.12,10.0.11.13\nSEED_IPS=10.0.11.11,10.0.11.12,10.0.11.13\n\nEOF\nchmod 0600 /opt/octastack/couchdb_native_cluster_ha/.env\n\ncat >/opt/octastack/couchdb_native_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  couchdb:\n    image: couchdb:3\n    container_name: octastack-couchdb\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    environment:\n      COUCHDB_USER: \"admin\"\n      COUCHDB_PASSWORD: \"change-me\"\n      COUCHDB_SECRET: \"replace-with-long-random-secret\"\n      ERL_FLAGS: \"-setcookie replace-with-erlang-cookie\"\n      NODENAME: \"couchdb@${CURRENT_IP}\"\n    volumes:\n      - data:/opt/couchdb/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Deploy CouchDB Native Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[couchdb_native_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/couchdb_native_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/couchdb_native_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/couchdb_native_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Initialize CouchDB Native Cluster HA node",
            "command": "set -euo pipefail\n\nlog() { printf '[couchdb-native-cluster-ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.11.11 10.0.11.12 10.0.11.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.11.11) NODE_NAME='couchdb-01'; NODE_ROLE='couchdb'; NODE_INDEX=1 ;;\n  10.0.11.12) NODE_NAME='couchdb-02'; NODE_ROLE='couchdb'; NODE_INDEX=2 ;;\n  10.0.11.13) NODE_NAME='couchdb-03'; NODE_ROLE='couchdb'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ncontainer_ready=0\nfor attempt in $(seq 1 60); do\n  if docker exec octastack-couchdb sh -lc \"curl -fsS http://admin:change-me@127.0.0.1:5984/_up\" >/dev/null 2>&1; then\n    container_ready=1\n    break\n  fi\n  sleep 5\ndone\nif [ \"$container_ready\" = \"1\" ]; then\n  log \"container octastack-couchdb is ready\"\nelse\ndocker logs octastack-couchdb --tail=120 || true\necho \"container octastack-couchdb did not become ready\" >&2\nexit 1\nfi\n\nif [ \"$NODE_INDEX\" != \"1\" ]; then\n  log \"cluster setup is driven by the first CouchDB member\"\n  exit 0\nfi\nfor member in 10.0.11.11 10.0.11.12 10.0.11.13; do\n  curl -fsS -X POST http://admin:change-me@127.0.0.1:5984/_cluster_setup \\\n    -H 'Content-Type: application/json' \\\n    --data-binary @- <<EOF || true\n{\"action\":\"enable_cluster\",\"bind_address\":\"0.0.0.0\",\"username\":\"admin\",\"password\":\"change-me\",\"node_count\":\"3\",\"remote_node\":\"$member\",\"remote_current_user\":\"admin\",\"remote_current_password\":\"change-me\"}\nEOF\n  if [ \"$member\" != \"10.0.11.11\" ]; then\n    curl -fsS -X POST http://admin:change-me@127.0.0.1:5984/_cluster_setup \\\n      -H 'Content-Type: application/json' \\\n      --data-binary @- <<EOF || true\n{\"action\":\"add_node\",\"host\":\"$member\",\"port\":5984,\"username\":\"admin\",\"password\":\"change-me\"}\nEOF\n  fi\ndone\ncurl -fsS -X POST http://admin:change-me@127.0.0.1:5984/_cluster_setup -H 'Content-Type: application/json' -d '{\"action\":\"finish_cluster\"}' || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document CouchDB Native Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/couchdb_native_cluster_ha-topology.md <<'EOF'\n# CouchDB Native Cluster HA\n\nMembers:\n- couchdb-01: 10.0.11.11 (couchdb)\n- couchdb-02: 10.0.11.12 (couchdb)\n- couchdb-03: 10.0.11.13 (couchdb)\n\nThree CouchDB members run native clustering with a shared cookie/secret and first-member cluster setup calls.\nEOF\ncat /tmp/couchdb_native_cluster_ha-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate CouchDB Native Cluster HA node",
            "command": "curl -fsS http://admin:change-me@127.0.0.1:5984/_membership\n",
            "sudo": true
          }
        },
        {
