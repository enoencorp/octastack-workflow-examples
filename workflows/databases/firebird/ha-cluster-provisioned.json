        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Firebird inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/firebird-inventory.ini <<'INVENTORY'\n[firebird]\n10.31.117.11 role=firebird name=firebird-01\n10.31.117.12 role=firebird name=firebird-02\n10.31.117.13 role=firebird name=firebird-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install Firebird container runtime",
            "command": "set -euo pipefail\ncat >/tmp/firebird-runtime.yml <<'PLAYBOOK'\n- hosts: firebird\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/firebird-inventory.ini /tmp/firebird-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render Firebird cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/firebird-deploy.yml <<'PLAYBOOK'\n- hosts: firebird\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/firebird\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/firebird/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            firebird:\n              image: firebirdsql/firebird:5.0\n              container_name: octastack-firebird\n              restart: unless-stopped\n              environment:\n                FIREBIRD_ROOT_PASSWORD: \"change-me\"\n              ports:\n                - \"3050:3050\"\n              volumes:\n                - data:/firebird/data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy Firebird cluster",
            "command": "set -euo pipefail\ncat >>/tmp/firebird-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/firebird/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/firebird/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/firebird/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/firebird-inventory.ini /tmp/firebird-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document Firebird topology",
            "command": "set -euo pipefail\ncat >/tmp/firebird-topology.md <<'EOF'\n# Firebird HA topology\n\nMembers:\n- firebird-01: 10.31.117.11 (firebird)\n- firebird-02: 10.31.117.12 (firebird)\n- firebird-03: 10.31.117.13 (firebird)\n\nThis example deploys one Firebird container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/firebird-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate Firebird cluster",
            "command": "set -euo pipefail\nansible -i /tmp/firebird-inventory.ini firebird -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
