        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare MariaDB Galera HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Render MariaDB Galera HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[mariadb_galera_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.2.11 10.0.2.12 10.0.2.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.2.11) NODE_NAME='mariadb-01'; NODE_ROLE='mariadb'; NODE_INDEX=1 ;;\n  10.0.2.12) NODE_NAME='mariadb-02'; NODE_ROLE='mariadb'; NODE_INDEX=2 ;;\n  10.0.2.13) NODE_NAME='mariadb-03'; NODE_ROLE='mariadb'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nif [ \"$NODE_INDEX\" = \"1\" ]; then\n  GALERA_BOOTSTRAP=\"--wsrep-new-cluster\"\nelse\n  GALERA_BOOTSTRAP=\"\"\nfi\n\ninstall -d -m 0750 /opt/octastack/mariadb_galera_ha\ninstall -d -m 0750 /var/lib/octastack/mariadb_galera_ha\ncat >/opt/octastack/mariadb_galera_ha/.env <<EOF\nMARIADB_ROOT_PASSWORD=change-me\nMARIADB_DATABASE=app_db\nMARIADB_USER=app_user\nMARIADB_PASSWORD=change-me\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.2.11\nCLUSTER_PEERS=10.0.2.11,10.0.2.12,10.0.2.13\nSEED_IPS=10.0.2.11,10.0.2.12,10.0.2.13\nGALERA_BOOTSTRAP=$GALERA_BOOTSTRAP\nGALERA_CLUSTER_ADDRESS=gcomm://10.0.2.11,10.0.2.12,10.0.2.13\nEOF\nchmod 0600 /opt/octastack/mariadb_galera_ha/.env\n\ncat >/opt/octastack/mariadb_galera_ha/compose.yml <<'COMPOSE'\nservices:\n  mariadb:\n    image: mariadb:11.4\n    container_name: octastack-mariadb\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      mariadbd\n      --bind-address=0.0.0.0\n      --binlog-format=ROW\n      --default-storage-engine=InnoDB\n      --innodb-autoinc-lock-mode=2\n      --wsrep-on=ON\n      --wsrep-provider=/usr/lib/galera/libgalera_smm.so\n      --wsrep-cluster-name=octastack-mariadb\n      --wsrep-cluster-address=${GALERA_CLUSTER_ADDRESS}\n      --wsrep-node-address=${CURRENT_IP}\n      --wsrep-node-name=${OCTASTACK_NODE_NAME}\n      ${GALERA_BOOTSTRAP}\n    volumes:\n      - data:/var/lib/mysql\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Deploy MariaDB Galera HA node",
            "command": "set -euo pipefail\nlog() { printf '[mariadb_galera_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/mariadb_galera_ha/compose.yml pull\ndocker compose -f /opt/octastack/mariadb_galera_ha/compose.yml up -d\ndocker compose -f /opt/octastack/mariadb_galera_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Document MariaDB Galera HA topology",
            "command": "set -euo pipefail\ncat >/tmp/mariadb_galera_ha-topology.md <<'EOF'\n# MariaDB Galera HA\n\nMembers:\n- mariadb-01: 10.0.2.11 (mariadb)\n- mariadb-02: 10.0.2.12 (mariadb)\n- mariadb-03: 10.0.2.13 (mariadb)\n\nThree MariaDB members form a synchronous Galera cluster with one deterministic bootstrap member and two joining members.\nEOF\ncat /tmp/mariadb_galera_ha-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Validate MariaDB Galera HA node",
            "command": "set -euo pipefail\ndocker exec octastack-mariadb mariadb -uroot -pchange-me -e \"SHOW STATUS LIKE 'wsrep_cluster_size'; SHOW STATUS LIKE 'wsrep_local_state_comment';\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
