          "id": "node_wait",
          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for existing host",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare MariaDB runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create MariaDB directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/mariadb\ninstall -d -m 0750 /var/lib/octastack/mariadb\ncat >/opt/octastack/mariadb/.env <<'EOF'\nMARIADB_ROOT_PASSWORD=change-me\nMARIADB_DATABASE=app_db\nMARIADB_USER=app_user\nMARIADB_PASSWORD=change-me\nEOF\nchmod 0600 /opt/octastack/mariadb/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render MariaDB compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/mariadb/compose.yml <<'COMPOSE'\nservices:\n  mariadb:\n    image: mariadb:11.4\n    container_name: octastack-mariadb\n    restart: unless-stopped\n    environment:\n      MARIADB_ROOT_PASSWORD: \"change-me\"\n      MARIADB_DATABASE: \"app_db\"\n      MARIADB_USER: \"app_user\"\n      MARIADB_PASSWORD: \"change-me\"\n    ports:\n      - \"3306:3306\"\n    volumes:\n      - data:/var/lib/mysql\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy MariaDB",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/mariadb/compose.yml pull\ndocker compose -f /opt/octastack/mariadb/compose.yml up -d\ndocker compose -f /opt/octastack/mariadb/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect MariaDB",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-mariadb\ndocker logs octastack-mariadb --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "MariaDB health check",
            "command": "docker exec octastack-mariadb mariadb-admin ping -uroot -pchange-me",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 4730
          },
          "data": {
            "label": "End"
          }
        }
