        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare MongoDB inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/mongodb-inventory.ini <<'INVENTORY'\n[mongodb]\n10.31.82.11 role=mongodb name=mongodb-01\n10.31.82.12 role=mongodb name=mongodb-02\n10.31.82.13 role=mongodb name=mongodb-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Install MongoDB container runtime",
            "command": "set -euo pipefail\ncat >/tmp/mongodb-runtime.yml <<'PLAYBOOK'\n- hosts: mongodb\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/mongodb-inventory.ini /tmp/mongodb-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render MongoDB cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/mongodb-deploy.yml <<'PLAYBOOK'\n- hosts: mongodb\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/mongodb\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/mongodb/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            mongodb:\n              image: mongo:7\n              container_name: octastack-mongodb\n              restart: unless-stopped\n              environment:\n                MONGO_INITDB_ROOT_USERNAME: \"root\"\n                MONGO_INITDB_ROOT_PASSWORD: \"change-me\"\n              ports:\n                - \"27017:27017\"\n              volumes:\n                - data:/data/db\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy MongoDB cluster",
            "command": "set -euo pipefail\ncat >>/tmp/mongodb-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/mongodb/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/mongodb/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/mongodb/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/mongodb-inventory.ini /tmp/mongodb-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Document MongoDB topology",
            "command": "set -euo pipefail\ncat >/tmp/mongodb-topology.md <<'EOF'\n# MongoDB HA topology\n\nMembers:\n- mongodb-01: 10.31.82.11 (mongodb)\n- mongodb-02: 10.31.82.12 (mongodb)\n- mongodb-03: 10.31.82.13 (mongodb)\n\nThis example deploys one MongoDB container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/mongodb-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Validate MongoDB cluster",
            "command": "set -euo pipefail\nansible -i /tmp/mongodb-inventory.ini mongodb -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 5000
          },
          "data": {
            "label": "MongoDB HA health check",
            "command": "docker exec octastack-mongodb mongosh --quiet --eval 'db.adminCommand({ ping: 1 })'",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
