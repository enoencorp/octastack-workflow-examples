        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Microsoft SQL Server runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Microsoft SQL Server directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/microsoft_sql_server\ninstall -d -m 0750 /var/lib/octastack/microsoft_sql_server\ncat >/opt/octastack/microsoft_sql_server/.env <<'EOF'\nACCEPT_EULA=Y\nMSSQL_SA_PASSWORD=ChangeMe123!\nEOF\nchmod 0600 /opt/octastack/microsoft_sql_server/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Microsoft SQL Server compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/microsoft_sql_server/compose.yml <<'COMPOSE'\nservices:\n  mssql:\n    image: mcr.microsoft.com/mssql/server:2022-latest\n    container_name: octastack-mssql\n    restart: unless-stopped\n    environment:\n      ACCEPT_EULA: \"Y\"\n      MSSQL_SA_PASSWORD: \"ChangeMe123!\"\n    ports:\n      - \"1433:1433\"\n    volumes:\n      - data:/var/opt/mssql\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Microsoft SQL Server",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/microsoft_sql_server/compose.yml pull\ndocker compose -f /opt/octastack/microsoft_sql_server/compose.yml up -d\ndocker compose -f /opt/octastack/microsoft_sql_server/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Microsoft SQL Server",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-mssql\ndocker logs octastack-mssql --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Microsoft SQL Server health check",
            "command": "docker exec octastack-mssql /opt/mssql-tools18/bin/sqlcmd -S localhost -U sa -P ChangeMe123! -C -Q 'SELECT 1'",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 4730
          },
          "data": {
            "label": "End"
          }
        }
