        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare MySQL inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/mysql-inventory.ini <<'INVENTORY'\n[mysql]\n10.31.80.11 role=mysql name=mysql-01\n10.31.80.12 role=mysql name=mysql-02\n10.31.80.13 role=mysql name=mysql-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Install MySQL container runtime",
            "command": "set -euo pipefail\ncat >/tmp/mysql-runtime.yml <<'PLAYBOOK'\n- hosts: mysql\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/mysql-inventory.ini /tmp/mysql-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render MySQL cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/mysql-deploy.yml <<'PLAYBOOK'\n- hosts: mysql\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/mysql\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/mysql/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            mysql:\n              image: mysql:8.4\n              container_name: octastack-mysql\n              restart: unless-stopped\n              environment:\n                MYSQL_ROOT_PASSWORD: \"change-me\"\n                MYSQL_DATABASE: \"app_db\"\n                MYSQL_USER: \"app_user\"\n                MYSQL_PASSWORD: \"change-me\"\n              ports:\n                - \"3306:3306\"\n              volumes:\n                - data:/var/lib/mysql\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy MySQL cluster",
            "command": "set -euo pipefail\ncat >>/tmp/mysql-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/mysql/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/mysql/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/mysql/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/mysql-inventory.ini /tmp/mysql-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Document MySQL topology",
            "command": "set -euo pipefail\ncat >/tmp/mysql-topology.md <<'EOF'\n# MySQL HA topology\n\nMembers:\n- mysql-01: 10.31.80.11 (mysql)\n- mysql-02: 10.31.80.12 (mysql)\n- mysql-03: 10.31.80.13 (mysql)\n\nThis example deploys one MySQL container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/mysql-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Validate MySQL cluster",
            "command": "set -euo pipefail\nansible -i /tmp/mysql-inventory.ini mysql -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 5000
          },
          "data": {
            "label": "MySQL HA health check",
            "command": "docker exec octastack-mysql mysqladmin ping -uroot -pchange-me",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 5405
          },
