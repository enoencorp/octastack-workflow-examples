        {
          "id": "node_wait",
          "type": "waitUntilUpNode",
          "position": {
            "x": 1545,
            "y": 2985
          },
          "data": {
            "label": "Wait for provisioned host",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4290
          },
          "data": {
            "label": "Prepare MySQL runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4695
          },
          "data": {
            "label": "Create MySQL directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/mysql\ninstall -d -m 0750 /var/lib/octastack/mysql\ncat >/opt/octastack/mysql/.env <<'EOF'\nMYSQL_ROOT_PASSWORD=change-me\nMYSQL_DATABASE=app_db\nMYSQL_USER=app_user\nMYSQL_PASSWORD=change-me\nEOF\nchmod 0600 /opt/octastack/mysql/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5100
          },
          "data": {
            "label": "Render MySQL compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/mysql/compose.yml <<'COMPOSE'\nservices:\n  mysql:\n    image: mysql:8.4\n    container_name: octastack-mysql\n    restart: unless-stopped\n    environment:\n      MYSQL_ROOT_PASSWORD: \"change-me\"\n      MYSQL_DATABASE: \"app_db\"\n      MYSQL_USER: \"app_user\"\n      MYSQL_PASSWORD: \"change-me\"\n    ports:\n      - \"3306:3306\"\n    volumes:\n      - data:/var/lib/mysql\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5505
          },
          "data": {
            "label": "Deploy MySQL",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/mysql/compose.yml pull\ndocker compose -f /opt/octastack/mysql/compose.yml up -d\ndocker compose -f /opt/octastack/mysql/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5910
          },
          "data": {
            "label": "Inspect MySQL",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-mysql\ndocker logs octastack-mysql --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 6315
          },
          "data": {
            "label": "MySQL health check",
            "command": "docker exec octastack-mysql mysqladmin ping -uroot -pchange-me",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 1085,
            "y": 6720
          },
          "data": {
            "label": "End"
          }
        }
