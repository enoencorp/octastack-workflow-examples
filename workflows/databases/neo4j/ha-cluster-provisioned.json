        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Neo4j inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/neo4j-inventory.ini <<'INVENTORY'\n[neo4j]\n10.31.89.11 role=neo4j name=neo4j-01\n10.31.89.12 role=neo4j name=neo4j-02\n10.31.89.13 role=neo4j name=neo4j-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install Neo4j container runtime",
            "command": "set -euo pipefail\ncat >/tmp/neo4j-runtime.yml <<'PLAYBOOK'\n- hosts: neo4j\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/neo4j-inventory.ini /tmp/neo4j-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render Neo4j cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/neo4j-deploy.yml <<'PLAYBOOK'\n- hosts: neo4j\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/neo4j\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/neo4j/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            neo4j:\n              image: neo4j:5\n              container_name: octastack-neo4j\n              restart: unless-stopped\n              environment:\n                NEO4J_AUTH: \"neo4j/change-me\"\n              ports:\n                - \"7474:7474\"\n                - \"7687:7687\"\n              volumes:\n                - data:/data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy Neo4j cluster",
            "command": "set -euo pipefail\ncat >>/tmp/neo4j-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/neo4j/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/neo4j/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/neo4j/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/neo4j-inventory.ini /tmp/neo4j-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document Neo4j topology",
            "command": "set -euo pipefail\ncat >/tmp/neo4j-topology.md <<'EOF'\n# Neo4j HA topology\n\nMembers:\n- neo4j-01: 10.31.89.11 (neo4j)\n- neo4j-02: 10.31.89.12 (neo4j)\n- neo4j-03: 10.31.89.13 (neo4j)\n\nThis example deploys one Neo4j container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/neo4j-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate Neo4j cluster",
            "command": "set -euo pipefail\nansible -i /tmp/neo4j-inventory.ini neo4j -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7430
          },
          "data": {
            "label": "Neo4j HA health check",
            "command": "docker exec octastack-neo4j cypher-shell -u neo4j -p change-me 'RETURN 1;'",
            "sudo": false
          }
        },
