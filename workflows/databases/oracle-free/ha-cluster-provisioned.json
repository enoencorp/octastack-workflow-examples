        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Oracle Database Free inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/oracle_database_free-inventory.ini <<'INVENTORY'\n[oracle_database_free]\n10.31.116.11 role=oracle name=oracle-database-free-01\n10.31.116.12 role=oracle name=oracle-database-free-02\n10.31.116.13 role=oracle name=oracle-database-free-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install Oracle Database Free container runtime",
            "command": "set -euo pipefail\ncat >/tmp/oracle_database_free-runtime.yml <<'PLAYBOOK'\n- hosts: oracle_database_free\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/oracle_database_free-inventory.ini /tmp/oracle_database_free-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render Oracle Database Free cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/oracle_database_free-deploy.yml <<'PLAYBOOK'\n- hosts: oracle_database_free\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/oracle_database_free\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/oracle_database_free/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            oracle-free:\n              image: gvenzl/oracle-free:23-slim\n              container_name: octastack-oracle-free\n              restart: unless-stopped\n              environment:\n                ORACLE_PASSWORD: \"ChangeMe123!\"\n              ports:\n                - \"1521:1521\"\n              volumes:\n                - data:/opt/oracle/oradata\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy Oracle Database Free cluster",
            "command": "set -euo pipefail\ncat >>/tmp/oracle_database_free-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/oracle_database_free/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/oracle_database_free/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/oracle_database_free/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/oracle_database_free-inventory.ini /tmp/oracle_database_free-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document Oracle Database Free topology",
            "command": "set -euo pipefail\ncat >/tmp/oracle_database_free-topology.md <<'EOF'\n# Oracle Database Free HA topology\n\nMembers:\n- oracle-database-free-01: 10.31.116.11 (oracle)\n- oracle-database-free-02: 10.31.116.12 (oracle)\n- oracle-database-free-03: 10.31.116.13 (oracle)\n\nThis example deploys one Oracle Database Free container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/oracle_database_free-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate Oracle Database Free cluster",
            "command": "set -euo pipefail\nansible -i /tmp/oracle_database_free-inventory.ini oracle_database_free -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
