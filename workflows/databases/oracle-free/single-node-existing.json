        {
          "id": "node_wait",
          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for existing host",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Oracle Database Free runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Oracle Database Free directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/oracle_database_free\ninstall -d -m 0750 /var/lib/octastack/oracle_database_free\ncat >/opt/octastack/oracle_database_free/.env <<'EOF'\nORACLE_PASSWORD=ChangeMe123!\nEOF\nchmod 0600 /opt/octastack/oracle_database_free/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Oracle Database Free compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/oracle_database_free/compose.yml <<'COMPOSE'\nservices:\n  oracle-free:\n    image: gvenzl/oracle-free:23-slim\n    container_name: octastack-oracle-free\n    restart: unless-stopped\n    environment:\n      ORACLE_PASSWORD: \"ChangeMe123!\"\n    ports:\n      - \"1521:1521\"\n    volumes:\n      - data:/opt/oracle/oradata\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Oracle Database Free",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/oracle_database_free/compose.yml pull\ndocker compose -f /opt/octastack/oracle_database_free/compose.yml up -d\ndocker compose -f /opt/octastack/oracle_database_free/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Oracle Database Free",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-oracle-free\ndocker logs octastack-oracle-free --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Oracle Database Free health check",
            "command": "docker exec octastack-oracle-free healthcheck.sh",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 4730
          },
          "data": {
            "label": "End"
          }
        }
