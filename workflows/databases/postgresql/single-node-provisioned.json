        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4290
          },
          "data": {
            "label": "Render PostgreSQL single-node installer",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/postgresql_single_node\ncat >/opt/octastack/postgresql_single_node/install.sh <<'OCTASTACK_INSTALLER'\nset -euo pipefail\nexport DEBIAN_FRONTEND=noninteractive\nsudo apt-get update\nsudo apt-get install -y postgresql postgresql-contrib\nsudo sed -i \"s/^#listen_addresses.*/listen_addresses = '*'/\" /etc/postgresql/*/main/postgresql.conf\nsudo tee -a /etc/postgresql/*/main/pg_hba.conf >/dev/null <<'EOF'\nhost all all 10.0.0.0/8 scram-sha-256\nEOF\nsudo systemctl enable --now postgresql\nsudo -u postgres psql -tc \"SELECT 1 FROM pg_roles WHERE rolname='app_user'\" | grep -q 1 || sudo -u postgres psql -c \"CREATE ROLE app_user LOGIN PASSWORD 'change-me';\"\nsudo -u postgres psql -tc \"SELECT 1 FROM pg_database WHERE datname='app_db'\" | grep -q 1 || sudo -u postgres createdb app_db -O app_user\n\nOCTASTACK_INSTALLER\nchmod 0750 /opt/octastack/postgresql_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4695
          },
          "data": {
            "label": "Review PostgreSQL single-node installer",
            "command": "set -euo pipefail\nbash -n /opt/octastack/postgresql_single_node/install.sh\nwc -l /opt/octastack/postgresql_single_node/install.sh\nsed -n '1,120p' /opt/octastack/postgresql_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5100
          },
          "data": {
            "label": "Execute PostgreSQL single-node installer",
            "command": "set -euo pipefail\n/opt/octastack/postgresql_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5505
          },
          "data": {
            "label": "Collect PostgreSQL single-node runtime status",
            "command": "set -euo pipefail\nsystemctl --failed --no-pager || true\nif command -v docker >/dev/null 2>&1; then docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}' || true; fi\nif command -v kubectl >/dev/null 2>&1; then kubectl get nodes -o wide || true; kubectl get pods -A || true; fi\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5910
          },
          "data": {
            "label": "PostgreSQL health check",
            "command": "pg_isready -h 127.0.0.1 -p 5432 && sudo -u postgres psql -c 'SELECT version();'",
            "sudo": false
          }
        },
