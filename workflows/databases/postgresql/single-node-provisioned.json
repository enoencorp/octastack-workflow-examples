    {
      "id": "node_wait",
      "type": "waitUntilUpNode",
      "position": {
        "x": 80,
        "y": 600
      },
      "data": {
        "label": "Wait for provisioned host",
        "timeout": "20",
        "interval": "10",
        "probes": [
          {
            "id": "probe-0",
            "type": "ssh",
            "host": "",
            "port": "22",
            "label": "SSH reachability"
          }
        ]
      }
    },
    {
      "id": "node_install",
      "type": "customNode",
      "position": {
        "x": 80,
        "y": 780
      },
      "data": {
        "label": "Install PostgreSQL",
        "customNodeId": "",
        "scriptType": "shell",
        "scriptContent": "set -euo pipefail\nexport DEBIAN_FRONTEND=noninteractive\nsudo apt-get update\nsudo apt-get install -y postgresql postgresql-contrib\nsudo sed -i \"s/^#listen_addresses.*/listen_addresses = '*'/\" /etc/postgresql/*/main/postgresql.conf\nsudo tee -a /etc/postgresql/*/main/pg_hba.conf >/dev/null <<'EOF'\nhost all all 10.0.0.0/8 scram-sha-256\nEOF\nsudo systemctl enable --now postgresql\nsudo -u postgres psql -tc \"SELECT 1 FROM pg_roles WHERE rolname='app_user'\" | grep -q 1 || sudo -u postgres psql -c \"CREATE ROLE app_user LOGIN PASSWORD 'change-me';\"\nsudo -u postgres psql -tc \"SELECT 1 FROM pg_database WHERE datname='app_db'\" | grep -q 1 || sudo -u postgres createdb app_db -O app_user\n",
        "sudo": true,
        "method": "GET",
        "path": "",
        "body": "{}"
      }
    },
    {
      "id": "node_health",
      "type": "configCommandNode",
      "position": {
        "x": 80,
        "y": 980
      },
      "data": {
        "label": "PostgreSQL health check",
        "command": "pg_isready -h 127.0.0.1 -p 5432 && sudo -u postgres psql -c 'SELECT version();'",
        "sudo": false
      }
    },
    {
