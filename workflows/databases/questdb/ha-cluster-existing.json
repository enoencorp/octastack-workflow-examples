        {
          "id": "node_wait_runner",
          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for automation runner",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare QuestDB inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/questdb-inventory.ini <<'INVENTORY'\n[questdb]\n10.31.93.11 role=questdb name=questdb-01\n10.31.93.12 role=questdb name=questdb-02\n10.31.93.13 role=questdb name=questdb-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Install QuestDB container runtime",
            "command": "set -euo pipefail\ncat >/tmp/questdb-runtime.yml <<'PLAYBOOK'\n- hosts: questdb\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/questdb-inventory.ini /tmp/questdb-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render QuestDB cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/questdb-deploy.yml <<'PLAYBOOK'\n- hosts: questdb\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/questdb\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/questdb/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            questdb:\n              image: questdb/questdb:8.1.0\n              container_name: octastack-questdb\n              restart: unless-stopped\n              ports:\n                - \"9000:9000\"\n                - \"8812:8812\"\n                - \"9009:9009\"\n              volumes:\n                - data:/var/lib/questdb\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy QuestDB cluster",
            "command": "set -euo pipefail\ncat >>/tmp/questdb-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/questdb/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/questdb/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/questdb/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/questdb-inventory.ini /tmp/questdb-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Document QuestDB topology",
            "command": "set -euo pipefail\ncat >/tmp/questdb-topology.md <<'EOF'\n# QuestDB HA topology\n\nMembers:\n- questdb-01: 10.31.93.11 (questdb)\n- questdb-02: 10.31.93.12 (questdb)\n- questdb-03: 10.31.93.13 (questdb)\n\nThis example deploys one QuestDB container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/questdb-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Validate QuestDB cluster",
            "command": "set -euo pipefail\nansible -i /tmp/questdb-inventory.ini questdb -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 5000
          },
          "data": {
            "label": "QuestDB HA health check",
            "command": "curl -fsS http://127.0.0.1:9000/",
            "sudo": false
          }
        },
        {
