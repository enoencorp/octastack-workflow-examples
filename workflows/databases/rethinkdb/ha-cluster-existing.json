        {
          "id": "node_wait_runner",
          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for automation runner",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare RethinkDB inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/rethinkdb-inventory.ini <<'INVENTORY'\n[rethinkdb]\n10.31.119.11 role=rethinkdb name=rethinkdb-01\n10.31.119.12 role=rethinkdb name=rethinkdb-02\n10.31.119.13 role=rethinkdb name=rethinkdb-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Install RethinkDB container runtime",
            "command": "set -euo pipefail\ncat >/tmp/rethinkdb-runtime.yml <<'PLAYBOOK'\n- hosts: rethinkdb\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/rethinkdb-inventory.ini /tmp/rethinkdb-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render RethinkDB cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/rethinkdb-deploy.yml <<'PLAYBOOK'\n- hosts: rethinkdb\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/rethinkdb\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/rethinkdb/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            rethinkdb:\n              image: rethinkdb:2.4\n              container_name: octastack-rethinkdb\n              restart: unless-stopped\n              ports:\n                - \"28015:28015\"\n                - \"8080:8080\"\n              volumes:\n                - data:/data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy RethinkDB cluster",
            "command": "set -euo pipefail\ncat >>/tmp/rethinkdb-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/rethinkdb/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/rethinkdb/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/rethinkdb/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/rethinkdb-inventory.ini /tmp/rethinkdb-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Document RethinkDB topology",
            "command": "set -euo pipefail\ncat >/tmp/rethinkdb-topology.md <<'EOF'\n# RethinkDB HA topology\n\nMembers:\n- rethinkdb-01: 10.31.119.11 (rethinkdb)\n- rethinkdb-02: 10.31.119.12 (rethinkdb)\n- rethinkdb-03: 10.31.119.13 (rethinkdb)\n\nThis example deploys one RethinkDB container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/rethinkdb-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Validate RethinkDB cluster",
            "command": "set -euo pipefail\nansible -i /tmp/rethinkdb-inventory.ini rethinkdb -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 5000
          },
          "data": {
            "label": "RethinkDB HA health check",
            "command": "curl -fsS http://127.0.0.1:8080/",
            "sudo": false
          }
        },
        {
