        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare RethinkDB Native Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Render RethinkDB Native Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[rethinkdb_native_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.19.11 10.0.19.12 10.0.19.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.19.11) NODE_NAME='rethinkdb-01'; NODE_ROLE='rethinkdb'; NODE_INDEX=1 ;;\n  10.0.19.12) NODE_NAME='rethinkdb-02'; NODE_ROLE='rethinkdb'; NODE_INDEX=2 ;;\n  10.0.19.13) NODE_NAME='rethinkdb-03'; NODE_ROLE='rethinkdb'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nif [ \"$NODE_INDEX\" = \"1\" ]; then\n  RETHINK_JOIN_ARG=\"\"\nelse\n  RETHINK_JOIN_ARG=\"--join ${FIRST_NODE_IP}:29015\"\nfi\n\ninstall -d -m 0750 /opt/octastack/rethinkdb_native_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/rethinkdb_native_cluster_ha\ncat >/opt/octastack/rethinkdb_native_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=RethinkDB\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.19.11\nCLUSTER_PEERS=10.0.19.11,10.0.19.12,10.0.19.13\nSEED_IPS=10.0.19.11,10.0.19.12,10.0.19.13\nRETHINK_JOIN_ARG=$RETHINK_JOIN_ARG\nEOF\nchmod 0600 /opt/octastack/rethinkdb_native_cluster_ha/.env\n\ncat >/opt/octastack/rethinkdb_native_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  rethinkdb:\n    image: rethinkdb:2.4\n    container_name: octastack-rethinkdb\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      rethinkdb --bind all --canonical-address ${CURRENT_IP} ${RETHINK_JOIN_ARG}\n    volumes:\n      - data:/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Deploy RethinkDB Native Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[rethinkdb_native_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/rethinkdb_native_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/rethinkdb_native_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/rethinkdb_native_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Document RethinkDB Native Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/rethinkdb_native_cluster_ha-topology.md <<'EOF'\n# RethinkDB Native Cluster HA\n\nMembers:\n- rethinkdb-01: 10.0.19.11 (rethinkdb)\n- rethinkdb-02: 10.0.19.12 (rethinkdb)\n- rethinkdb-03: 10.0.19.13 (rethinkdb)\n\nThree RethinkDB members form a native cluster; non-primary members join the generated first member.\nEOF\ncat /tmp/rethinkdb_native_cluster_ha-topology.md\n",
            "sudo": true
          }
        },
