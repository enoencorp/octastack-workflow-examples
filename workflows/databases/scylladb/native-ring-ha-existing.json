        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 3600
          },
          "data": {
            "label": "Prepare ScyllaDB Native Ring HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4005
          },
          "data": {
            "label": "Render ScyllaDB Native Ring HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[scylladb_native_ring_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.5.11 10.0.5.12 10.0.5.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.5.11) NODE_NAME='scylladb-01'; NODE_ROLE='scylladb'; NODE_INDEX=1 ;;\n  10.0.5.12) NODE_NAME='scylladb-02'; NODE_ROLE='scylladb'; NODE_INDEX=2 ;;\n  10.0.5.13) NODE_NAME='scylladb-03'; NODE_ROLE='scylladb'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/scylladb_native_ring_ha\ninstall -d -m 0750 /var/lib/octastack/scylladb_native_ring_ha\ncat >/opt/octastack/scylladb_native_ring_ha/.env <<EOF\nOCTASTACK_SERVICE=ScyllaDB\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.5.11\nCLUSTER_PEERS=10.0.5.11,10.0.5.12,10.0.5.13\nSEED_IPS=10.0.5.11,10.0.5.12,10.0.5.13\n\nEOF\nchmod 0600 /opt/octastack/scylladb_native_ring_ha/.env\n\ncat >/opt/octastack/scylladb_native_ring_ha/compose.yml <<'COMPOSE'\nservices:\n  scylladb:\n    image: scylladb/scylla:6.1\n    container_name: octastack-scylladb\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      --smp 2 --memory 4G --overprovisioned 1 --seeds=${SEED_IPS} --listen-address=${CURRENT_IP} --rpc-address=0.0.0.0 --broadcast-address=${CURRENT_IP} --broadcast-rpc-address=${CURRENT_IP}\n    volumes:\n      - data:/var/lib/scylla\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4410
          },
          "data": {
            "label": "Deploy ScyllaDB Native Ring HA node",
            "command": "set -euo pipefail\nlog() { printf '[scylladb_native_ring_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/scylladb_native_ring_ha/compose.yml pull\ndocker compose -f /opt/octastack/scylladb_native_ring_ha/compose.yml up -d\ndocker compose -f /opt/octastack/scylladb_native_ring_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4815
          },
          "data": {
            "label": "Document ScyllaDB Native Ring HA topology",
            "command": "set -euo pipefail\ncat >/tmp/scylladb_native_ring_ha-topology.md <<'EOF'\n# ScyllaDB Native Ring HA\n\nMembers:\n- scylladb-01: 10.0.5.11 (scylladb)\n- scylladb-02: 10.0.5.12 (scylladb)\n- scylladb-03: 10.0.5.13 (scylladb)\n\nThree ScyllaDB members form a native ring with generated seeds and per-node broadcast addresses.\nEOF\ncat /tmp/scylladb_native_ring_ha-topology.md\n",
            "sudo": true
          }
        },
