        },
        {
          "id": "node_wait",
          "type": "waitUntilUpNode",
          "position": {
            "x": 1545,
            "y": 2985
          },
          "data": {
            "label": "Wait for provisioned host",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4290
          },
          "data": {
            "label": "Prepare ScyllaDB runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4695
          },
          "data": {
            "label": "Create ScyllaDB directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/scylladb\ninstall -d -m 0750 /var/lib/octastack/scylladb\ncat >/opt/octastack/scylladb/.env <<'EOF'\nOCTASTACK_SERVICE=ScyllaDB\nEOF\nchmod 0600 /opt/octastack/scylladb/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5100
          },
          "data": {
            "label": "Render ScyllaDB compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/scylladb/compose.yml <<'COMPOSE'\nservices:\n  scylladb:\n    image: scylladb/scylla:6.1\n    container_name: octastack-scylladb\n    restart: unless-stopped\n    command: \"--smp 2 --memory 4G --overprovisioned 1\"\n    ports:\n      - \"9042:9042\"\n    volumes:\n      - data:/var/lib/scylla\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5505
          },
          "data": {
            "label": "Deploy ScyllaDB",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/scylladb/compose.yml pull\ndocker compose -f /opt/octastack/scylladb/compose.yml up -d\ndocker compose -f /opt/octastack/scylladb/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5910
          },
          "data": {
            "label": "Inspect ScyllaDB",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-scylladb\ndocker logs octastack-scylladb --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 6315
          },
          "data": {
            "label": "ScyllaDB health check",
            "command": "docker exec octastack-scylladb nodetool status",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 1085,
            "y": 6720
          },
          "data": {
            "label": "End"
          }
        }
