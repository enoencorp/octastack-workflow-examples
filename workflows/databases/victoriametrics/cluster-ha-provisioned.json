        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 3150,
            "y": 5000
          },
          "data": {
            "label": "Prepare VictoriaMetrics Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 3150,
            "y": 5405
          },
          "data": {
            "label": "Render VictoriaMetrics Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[victoriametrics_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.13.11 10.0.13.12 10.0.13.13 10.0.13.21 10.0.13.22 10.0.13.31 10.0.13.32 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.13.11) NODE_NAME='victoriametrics-storage-01'; NODE_ROLE='vmstorage'; NODE_INDEX=1 ;;\n  10.0.13.12) NODE_NAME='victoriametrics-storage-02'; NODE_ROLE='vmstorage'; NODE_INDEX=2 ;;\n  10.0.13.13) NODE_NAME='victoriametrics-storage-03'; NODE_ROLE='vmstorage'; NODE_INDEX=3 ;;\n  10.0.13.21) NODE_NAME='victoriametrics-select-01'; NODE_ROLE='vmselect'; NODE_INDEX=4 ;;\n  10.0.13.22) NODE_NAME='victoriametrics-select-02'; NODE_ROLE='vmselect'; NODE_INDEX=5 ;;\n  10.0.13.31) NODE_NAME='victoriametrics-insert-01'; NODE_ROLE='vminsert'; NODE_INDEX=6 ;;\n  10.0.13.32) NODE_NAME='victoriametrics-insert-02'; NODE_ROLE='vminsert'; NODE_INDEX=7 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nROLE_IMAGE=\"\"\nROLE_COMMAND=\"\"\ncase \"$NODE_ROLE\" in\n  vmstorage) ROLE_IMAGE=\"victoriametrics/vmstorage:v1.103.0\"; ROLE_COMMAND=\"-retentionPeriod=30d -storageDataPath=/storage -httpListenAddr=:8482 -vminsertAddr=:8400 -vmselectAddr=:8401\" ;;\n  vmselect) ROLE_IMAGE=\"victoriametrics/vmselect:v1.103.0\"; ROLE_COMMAND=\"-httpListenAddr=:8481 -storageNode=10.0.13.11:8401 -storageNode=10.0.13.12:8401 -storageNode=10.0.13.13:8401\" ;;\n  vminsert) ROLE_IMAGE=\"victoriametrics/vminsert:v1.103.0\"; ROLE_COMMAND=\"-httpListenAddr=:8480 -storageNode=10.0.13.11:8400 -storageNode=10.0.13.12:8400 -storageNode=10.0.13.13:8400\" ;;\n  *) log \"unsupported role $NODE_ROLE\"; exit 1 ;;\nesac\n\ninstall -d -m 0750 /opt/octastack/victoriametrics_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/victoriametrics_cluster_ha\ncat >/opt/octastack/victoriametrics_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=VictoriaMetrics\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.13.11\nCLUSTER_PEERS=10.0.13.11,10.0.13.12,10.0.13.13,10.0.13.21,10.0.13.22,10.0.13.31,10.0.13.32\nSEED_IPS=10.0.13.11,10.0.13.12,10.0.13.13\nROLE_IMAGE=$ROLE_IMAGE\nROLE_COMMAND=$ROLE_COMMAND\n\nEOF\nchmod 0600 /opt/octastack/victoriametrics_cluster_ha/.env\n\ncat >/opt/octastack/victoriametrics_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  victoriametrics:\n    image: ${ROLE_IMAGE}\n    container_name: octastack-victoriametrics\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      ${ROLE_COMMAND}\n    volumes:\n      - data:/storage\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
