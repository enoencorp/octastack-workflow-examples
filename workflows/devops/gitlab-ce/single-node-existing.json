        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare GitLab CE runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create GitLab CE directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/gitlab_ce\ninstall -d -m 0750 /var/lib/octastack/gitlab_ce\ncat >/opt/octastack/gitlab_ce/.env <<'EOF'\nGITLAB_OMNIBUS_CONFIG=external_url 'http://gitlab.example.internal'\nEOF\nchmod 0600 /opt/octastack/gitlab_ce/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render GitLab CE compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/gitlab_ce/compose.yml <<'COMPOSE'\nservices:\n  gitlab:\n    image: gitlab/gitlab-ce:17.3.0-ce.0\n    container_name: octastack-gitlab\n    restart: unless-stopped\n    environment:\n      GITLAB_OMNIBUS_CONFIG: \"external_url 'http://gitlab.example.internal'\"\n    ports:\n      - \"80:80\"\n      - \"443:443\"\n      - \"2222:22\"\n    volumes:\n      - data:/var/opt/gitlab\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy GitLab CE",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/gitlab_ce/compose.yml pull\ndocker compose -f /opt/octastack/gitlab_ce/compose.yml up -d\ndocker compose -f /opt/octastack/gitlab_ce/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect GitLab CE",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-gitlab\ndocker logs octastack-gitlab --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "GitLab CE health check",
            "command": "docker exec octastack-gitlab gitlab-ctl status",
            "sudo": false
          }
        },
        {
