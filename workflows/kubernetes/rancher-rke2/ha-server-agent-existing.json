        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1590,
            "y": 3600
          },
          "data": {
            "label": "Render Rancher RKE2 HA installer",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/rancher_rke2_ha\ncat >/opt/octastack/rancher_rke2_ha/install.sh <<'OCTASTACK_INSTALLER'\nset -euo pipefail\n\nlog() { printf '[rke2-ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.97.11 10.0.97.12 10.0.97.13 10.0.97.21 10.0.97.22 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.97.11) NODE_NAME='rke2-server-01'; NODE_ROLE='rke2_server'; NODE_INDEX=1 ;;\n  10.0.97.12) NODE_NAME='rke2-server-02'; NODE_ROLE='rke2_server'; NODE_INDEX=2 ;;\n  10.0.97.13) NODE_NAME='rke2-server-03'; NODE_ROLE='rke2_server'; NODE_INDEX=3 ;;\n  10.0.97.21) NODE_NAME='rke2-agent-01'; NODE_ROLE='rke2_agent'; NODE_INDEX=4 ;;\n  10.0.97.22) NODE_NAME='rke2-agent-02'; NODE_ROLE='rke2_agent'; NODE_INDEX=5 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nwait_for_tcp() {\n  host=\"$1\"\n  port=\"$2\"\n  timeout=\"${3:-180}\"\n  start=\"$(date +%s)\"\n  while ! timeout 2 bash -c \"cat < /dev/null > /dev/tcp/$host/$port\" >/dev/null 2>&1; do\n    now=\"$(date +%s)\"\n    if [ \"$((now - start))\" -ge \"$timeout\" ]; then\n      log \"timeout waiting for $host:$port\"\n      return 1\n    fi\n    sleep 5\n  done\n}\n\nif [ \"$CURRENT_IP\" = \"10.0.97.11\" ]; then\n  log \"installing first RKE2 server\"\n  curl -sfL https://get.rke2.io | INSTALL_RKE2_TYPE=server sh -\n  systemctl enable --now rke2-server\n  export KUBECONFIG=/etc/rancher/rke2/rke2.yaml\n  curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash\n  kubectl create namespace cattle-system --dry-run=client -o yaml | kubectl apply -f -\n  helm repo add jetstack https://charts.jetstack.io\n  helm repo add rancher-latest https://releases.rancher.com/server-charts/latest\n  helm repo update\n  helm upgrade --install cert-manager jetstack/cert-manager --namespace cert-manager --create-namespace --set crds.enabled=true\n  helm upgrade --install rancher rancher-latest/rancher --namespace cattle-system --set hostname=rancher.example.internal --set bootstrapPassword=change-me\nelif [ \"$NODE_ROLE\" = \"rke2_server\" ]; then\n  log \"joining RKE2 server to 10.0.97.11\"\n  wait_for_tcp \"10.0.97.11\" 9345 300\n  mkdir -p /etc/rancher/rke2\n  {\n    echo \"server: https://10.0.97.11:9345\"\n    echo \"token: replace-with-rke2-token\"\n  } >/etc/rancher/rke2/config.yaml\n  curl -sfL https://get.rke2.io | INSTALL_RKE2_TYPE=server sh -\n  systemctl enable --now rke2-server\nelse\n  log \"joining RKE2 agent to 10.0.97.11\"\n  wait_for_tcp \"10.0.97.11\" 9345 300\n  mkdir -p /etc/rancher/rke2\n  {\n    echo \"server: https://10.0.97.11:9345\"\n    echo \"token: replace-with-rke2-token\"\n  } >/etc/rancher/rke2/config.yaml\n  curl -sfL https://get.rke2.io | INSTALL_RKE2_TYPE=agent sh -\n  systemctl enable --now rke2-agent\nfi\n\nOCTASTACK_INSTALLER\nchmod 0750 /opt/octastack/rancher_rke2_ha/install.sh\n",
            "sudo": true
          }
        },
