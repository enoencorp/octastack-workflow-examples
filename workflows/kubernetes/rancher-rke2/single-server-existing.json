    {
      "id": "node_install",
      "type": "customNode",
      "position": {
        "x": 80,
        "y": 580
      },
      "data": {
        "label": "Install Rancher RKE2",
        "customNodeId": "",
        "scriptType": "shell",
        "scriptContent": "set -euo pipefail\ncurl -sfL https://get.rke2.io | sudo INSTALL_RKE2_TYPE=server sh -\nsudo systemctl enable --now rke2-server\nmkdir -p \"$HOME/.kube\"\nsudo cp /etc/rancher/rke2/rke2.yaml \"$HOME/.kube/config\"\nsudo chown \"$(id -u):$(id -g)\" \"$HOME/.kube/config\"\nexport KUBECONFIG=\"$HOME/.kube/config\"\ncurl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash\nkubectl create namespace cattle-system --dry-run=client -o yaml | kubectl apply -f -\nhelm repo add jetstack https://charts.jetstack.io\nhelm repo add rancher-latest https://releases.rancher.com/server-charts/latest\nhelm repo update\nhelm upgrade --install cert-manager jetstack/cert-manager --namespace cert-manager --create-namespace --set crds.enabled=true\nhelm upgrade --install rancher rancher-latest/rancher --namespace cattle-system --set hostname=rancher.example.internal --set bootstrapPassword=change-me\n",
        "sudo": true,
        "method": "GET",
        "path": "",
        "body": "{}"
      }
    },
    {
      "id": "node_health",
      "type": "configCommandNode",
      "position": {
        "x": 80,
        "y": 780
      },
      "data": {
        "label": "Rancher RKE2 health check",
        "command": "sudo /var/lib/rancher/rke2/bin/kubectl --kubeconfig /etc/rancher/rke2/rke2.yaml get nodes -o wide",
        "sudo": false
      }
    },
    {
