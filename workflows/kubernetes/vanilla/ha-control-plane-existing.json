        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Render Vanilla Kubernetes HA installer",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/vanilla_kubernetes_ha\ncat >/opt/octastack/vanilla_kubernetes_ha/install.sh <<'OCTASTACK_INSTALLER'\nset -euo pipefail\nsudo apt-get update\nsudo apt-get install -y ansible sshpass\ncat >/tmp/vanilla-k8s-ha.ini <<'INVENTORY'\n[control_plane]\n10.30.50.11 node_name=k8s-cp-01\n10.30.50.12 node_name=k8s-cp-02\n10.30.50.13 node_name=k8s-cp-03\n\n[worker]\n10.30.50.21 node_name=k8s-worker-01\n10.30.50.22 node_name=k8s-worker-02\nINVENTORY\ncat >/tmp/vanilla-k8s-ha.yml <<'PLAYBOOK'\n- hosts: all\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        swapoff -a\n        modprobe br_netfilter\n        sysctl -w net.bridge.bridge-nf-call-iptables=1\n        apt-get update\n        apt-get install -y containerd apt-transport-https ca-certificates curl gpg\n        systemctl enable --now containerd\n    - ansible.builtin.shell: |\n        mkdir -p /etc/apt/keyrings\n        curl -fsSL https://pkgs.k8s.io/core:/stable:/v1.30/deb/Release.key | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg\n        echo \"deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.30/deb/ /\" > /etc/apt/sources.list.d/kubernetes.list\n        apt-get update\n        apt-get install -y kubelet kubeadm kubectl\n\n- hosts: control_plane[0]\n  become: true\n  tasks:\n    - ansible.builtin.shell: kubeadm init --control-plane-endpoint \"10.30.50.10:6443\" --upload-certs --pod-network-cidr=192.168.0.0/16\n    - ansible.builtin.shell: kubectl --kubeconfig /etc/kubernetes/admin.conf apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.27.3/manifests/calico.yaml\n\n- hosts: control_plane:!control_plane[0]\n  become: true\n  tasks:\n    - ansible.builtin.debug:\n        msg: \"Join additional control plane nodes using the kubeadm join command printed by the first control plane.\"\n\n- hosts: worker\n  become: true\n  tasks:\n    - ansible.builtin.debug:\n        msg: \"Join worker nodes using the kubeadm join command printed by the first control plane.\"\nPLAYBOOK\nansible-playbook -i /tmp/vanilla-k8s-ha.ini /tmp/vanilla-k8s-ha.yml\n\nOCTASTACK_INSTALLER\nchmod 0750 /opt/octastack/vanilla_kubernetes_ha/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Review Vanilla Kubernetes HA installer",
            "command": "set -euo pipefail\nbash -n /opt/octastack/vanilla_kubernetes_ha/install.sh\nwc -l /opt/octastack/vanilla_kubernetes_ha/install.sh\nsed -n '1,120p' /opt/octastack/vanilla_kubernetes_ha/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Execute Vanilla Kubernetes HA installer",
            "command": "set -euo pipefail\n/opt/octastack/vanilla_kubernetes_ha/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Collect Vanilla Kubernetes HA runtime status",
            "command": "set -euo pipefail\nsystemctl --failed --no-pager || true\nif command -v docker >/dev/null 2>&1; then docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}' || true; fi\nif command -v kubectl >/dev/null 2>&1; then kubectl get nodes -o wide || true; kubectl get pods -A || true; fi\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 5000
          },
          "data": {
            "label": "Vanilla Kubernetes HA health check",
            "command": "kubectl --kubeconfig /etc/kubernetes/admin.conf get nodes -o wide",
            "sudo": false
          }
        },
