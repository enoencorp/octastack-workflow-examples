          "id": "node_install",
          "type": "customNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Install Vanilla Kubernetes",
            "customNodeId": "",
            "scriptType": "shell",
            "scriptContent": "set -euo pipefail\nsudo apt-get update\nsudo apt-get install -y apt-transport-https ca-certificates curl gpg\nsudo swapoff -a\nsudo modprobe br_netfilter\nsudo sysctl -w net.bridge.bridge-nf-call-iptables=1\nsudo apt-get install -y containerd\nsudo systemctl enable --now containerd\ncurl -fsSL https://pkgs.k8s.io/core:/stable:/v1.30/deb/Release.key | sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg\necho \"deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.30/deb/ /\" | sudo tee /etc/apt/sources.list.d/kubernetes.list\nsudo apt-get update\nsudo apt-get install -y kubelet kubeadm kubectl\nsudo kubeadm init --pod-network-cidr=192.168.0.0/16\nmkdir -p \"$HOME/.kube\"\nsudo cp /etc/kubernetes/admin.conf \"$HOME/.kube/config\"\nsudo chown \"$(id -u):$(id -g)\" \"$HOME/.kube/config\"\nkubectl apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.27.3/manifests/calico.yaml\n",
            "sudo": true,
            "method": "GET",
            "path": "",
            "body": "{}"
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3600
          },
          "data": {
            "label": "Vanilla Kubernetes health check",
            "command": "kubectl get nodes -o wide && kubectl get pods -A",
            "sudo": false
          }
