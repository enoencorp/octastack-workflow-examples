        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4290
          },
          "data": {
            "label": "Render Vanilla Kubernetes single-node installer",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/vanilla_kubernetes_single_node\ncat >/opt/octastack/vanilla_kubernetes_single_node/install.sh <<'OCTASTACK_INSTALLER'\nset -euo pipefail\nsudo apt-get update\nsudo apt-get install -y apt-transport-https ca-certificates curl gpg\nsudo swapoff -a\nsudo modprobe br_netfilter\nsudo sysctl -w net.bridge.bridge-nf-call-iptables=1\nsudo apt-get install -y containerd\nsudo systemctl enable --now containerd\ncurl -fsSL https://pkgs.k8s.io/core:/stable:/v1.30/deb/Release.key | sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg\necho \"deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.30/deb/ /\" | sudo tee /etc/apt/sources.list.d/kubernetes.list\nsudo apt-get update\nsudo apt-get install -y kubelet kubeadm kubectl\nsudo kubeadm init --pod-network-cidr=192.168.0.0/16\nmkdir -p \"$HOME/.kube\"\nsudo cp /etc/kubernetes/admin.conf \"$HOME/.kube/config\"\nsudo chown \"$(id -u):$(id -g)\" \"$HOME/.kube/config\"\nkubectl apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.27.3/manifests/calico.yaml\n\nOCTASTACK_INSTALLER\nchmod 0750 /opt/octastack/vanilla_kubernetes_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 4695
          },
          "data": {
            "label": "Review Vanilla Kubernetes single-node installer",
            "command": "set -euo pipefail\nbash -n /opt/octastack/vanilla_kubernetes_single_node/install.sh\nwc -l /opt/octastack/vanilla_kubernetes_single_node/install.sh\nsed -n '1,120p' /opt/octastack/vanilla_kubernetes_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5100
          },
          "data": {
            "label": "Execute Vanilla Kubernetes single-node installer",
            "command": "set -euo pipefail\n/opt/octastack/vanilla_kubernetes_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5505
          },
          "data": {
            "label": "Collect Vanilla Kubernetes single-node runtime status",
            "command": "set -euo pipefail\nsystemctl --failed --no-pager || true\nif command -v docker >/dev/null 2>&1; then docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}' || true; fi\nif command -v kubectl >/dev/null 2>&1; then kubectl get nodes -o wide || true; kubectl get pods -A || true; fi\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 1035,
            "y": 5910
          },
          "data": {
            "label": "Vanilla Kubernetes health check",
            "command": "kubectl get nodes -o wide && kubectl get pods -A",
            "sudo": false
          }
        },
