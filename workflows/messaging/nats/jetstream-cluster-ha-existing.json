        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 3600
          },
          "data": {
            "label": "Prepare NATS JetStream Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4005
          },
          "data": {
            "label": "Render NATS JetStream Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[nats_jetstream_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.82.11 10.0.82.12 10.0.82.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.82.11) NODE_NAME='nats-jetstream-01'; NODE_ROLE='nats'; NODE_INDEX=1 ;;\n  10.0.82.12) NODE_NAME='nats-jetstream-02'; NODE_ROLE='nats'; NODE_INDEX=2 ;;\n  10.0.82.13) NODE_NAME='nats-jetstream-03'; NODE_ROLE='nats'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/nats_jetstream_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/nats_jetstream_cluster_ha\ncat >/opt/octastack/nats_jetstream_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=NATS JetStream\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.82.11\nCLUSTER_PEERS=10.0.82.11,10.0.82.12,10.0.82.13\nSEED_IPS=10.0.82.11,10.0.82.12,10.0.82.13\n\nEOF\nchmod 0600 /opt/octastack/nats_jetstream_cluster_ha/.env\n\ncat >/opt/octastack/nats_jetstream_cluster_ha/nats.conf <<NATS\nserver_name: ${OCTASTACK_NODE_NAME}\nlisten: 0.0.0.0:4222\nhttp: 0.0.0.0:8222\njetstream {\n  store_dir: /data/jetstream\n}\ncluster {\n  name: octastack-nats\n  listen: 0.0.0.0:6222\n  routes: [\n    nats-route://10.0.82.11:6222,\n    nats-route://10.0.82.12:6222,\n    nats-route://10.0.82.13:6222\n  ]\n}\nNATS\n\ncat >/opt/octastack/nats_jetstream_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  nats:\n    image: nats:2.10\n    container_name: octastack-nats\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      -c /etc/nats/nats.conf\n    volumes:\n      - data:/data\n      - /opt/octastack/nats_jetstream_cluster_ha/nats.conf:/etc/nats/nats.conf:ro\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4410
          },
          "data": {
            "label": "Deploy NATS JetStream Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[nats_jetstream_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/nats_jetstream_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/nats_jetstream_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/nats_jetstream_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4815
          },
          "data": {
            "label": "Document NATS JetStream Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/nats_jetstream_cluster_ha-topology.md <<'EOF'\n# NATS JetStream Cluster HA\n\nMembers:\n- nats-jetstream-01: 10.0.82.11 (nats)\n- nats-jetstream-02: 10.0.82.12 (nats)\n- nats-jetstream-03: 10.0.82.13 (nats)\n\nThree NATS members form a JetStream-enabled cluster with generated route peers and persistent storage.\nEOF\ncat /tmp/nats_jetstream_cluster_ha-topology.md\n",
            "sudo": true
          }
        },
