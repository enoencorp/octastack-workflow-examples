        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Apache Pulsar inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/apache_pulsar-inventory.ini <<'INVENTORY'\n[apache_pulsar]\n10.31.101.11 role=pulsar name=apache-pulsar-01\n10.31.101.12 role=pulsar name=apache-pulsar-02\n10.31.101.13 role=pulsar name=apache-pulsar-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install Apache Pulsar container runtime",
            "command": "set -euo pipefail\ncat >/tmp/apache_pulsar-runtime.yml <<'PLAYBOOK'\n- hosts: apache_pulsar\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/apache_pulsar-inventory.ini /tmp/apache_pulsar-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render Apache Pulsar cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/apache_pulsar-deploy.yml <<'PLAYBOOK'\n- hosts: apache_pulsar\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/apache_pulsar\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/apache_pulsar/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            pulsar:\n              image: apachepulsar/pulsar:3.3.0\n              container_name: octastack-pulsar\n              restart: unless-stopped\n              command: \"bin/pulsar standalone\"\n              ports:\n                - \"6650:6650\"\n                - \"8080:8080\"\n              volumes:\n                - data:/pulsar/data\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy Apache Pulsar cluster",
            "command": "set -euo pipefail\ncat >>/tmp/apache_pulsar-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/apache_pulsar/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/apache_pulsar/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/apache_pulsar/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/apache_pulsar-inventory.ini /tmp/apache_pulsar-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document Apache Pulsar topology",
            "command": "set -euo pipefail\ncat >/tmp/apache_pulsar-topology.md <<'EOF'\n# Apache Pulsar HA topology\n\nMembers:\n- apache-pulsar-01: 10.31.101.11 (pulsar)\n- apache-pulsar-02: 10.31.101.12 (pulsar)\n- apache-pulsar-03: 10.31.101.13 (pulsar)\n\nThis example deploys one Apache Pulsar container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/apache_pulsar-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate Apache Pulsar cluster",
            "command": "set -euo pipefail\nansible -i /tmp/apache_pulsar-inventory.ini apache_pulsar -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
