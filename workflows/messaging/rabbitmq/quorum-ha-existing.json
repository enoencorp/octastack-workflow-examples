          "data": {
            "label": "Render RabbitMQ Quorum HA installer",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/rabbitmq_quorum_ha\ncat >/opt/octastack/rabbitmq_quorum_ha/install.sh <<'OCTASTACK_INSTALLER'\nset -euo pipefail\nsudo apt-get update\nsudo apt-get install -y ansible sshpass\ncat >/tmp/rabbitmq-ha.ini <<'INVENTORY'\n[rabbitmq]\n10.30.40.11 node_name=rabbitmq-01\n10.30.40.12 node_name=rabbitmq-02\n10.30.40.13 node_name=rabbitmq-03\nINVENTORY\ncat >/tmp/rabbitmq-ha.yml <<'PLAYBOOK'\n- hosts: rabbitmq\n  become: true\n  tasks:\n    - ansible.builtin.apt:\n        name: rabbitmq-server\n        state: present\n        update_cache: true\n    - ansible.builtin.copy:\n        dest: /var/lib/rabbitmq/.erlang.cookie\n        owner: rabbitmq\n        group: rabbitmq\n        mode: \"0400\"\n        content: \"OCTASTACKRABBITMQCOOKIE\"\n    - ansible.builtin.service:\n        name: rabbitmq-server\n        state: restarted\n        enabled: true\n    - ansible.builtin.shell: rabbitmq-plugins enable rabbitmq_management\n    - ansible.builtin.shell: |\n        rabbitmqctl stop_app\n        rabbitmqctl reset\n        rabbitmqctl join_cluster rabbit@10.30.40.11\n        rabbitmqctl start_app\n      when: inventory_hostname != \"10.30.40.11\"\n    - ansible.builtin.shell: |\n        rabbitmqctl set_policy ha-quorum \"^ha\\.\" '{\"queue-type\":\"quorum\"}' --apply-to queues\n        rabbitmqctl add_user app_user change-me || true\n        rabbitmqctl set_permissions -p / app_user \".*\" \".*\" \".*\"\n      when: inventory_hostname == \"10.30.40.11\"\nPLAYBOOK\nansible-playbook -i /tmp/rabbitmq-ha.ini /tmp/rabbitmq-ha.yml\n\nOCTASTACK_INSTALLER\nchmod 0750 /opt/octastack/rabbitmq_quorum_ha/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Review RabbitMQ Quorum HA installer",
            "command": "set -euo pipefail\nbash -n /opt/octastack/rabbitmq_quorum_ha/install.sh\nwc -l /opt/octastack/rabbitmq_quorum_ha/install.sh\nsed -n '1,120p' /opt/octastack/rabbitmq_quorum_ha/install.sh\n",
            "sudo": true
