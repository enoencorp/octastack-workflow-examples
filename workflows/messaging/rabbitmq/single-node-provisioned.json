          "data": {
            "label": "Install RabbitMQ",
            "customNodeId": "",
            "scriptType": "shell",
            "scriptContent": "set -euo pipefail\nsudo apt-get update\nsudo apt-get install -y rabbitmq-server\nsudo systemctl enable --now rabbitmq-server\nsudo rabbitmq-plugins enable rabbitmq_management\nsudo rabbitmqctl add_user app_user change-me || true\nsudo rabbitmqctl set_permissions -p / app_user \".*\" \".*\" \".*\"\n",
            "sudo": true,
            "method": "GET",
            "path": "",
            "body": "{}"
