        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 3600
          },
          "data": {
            "label": "Prepare Redpanda Native Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4005
          },
          "data": {
            "label": "Render Redpanda Native Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[redpanda_native_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.83.11 10.0.83.12 10.0.83.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.83.11) NODE_NAME='redpanda-01'; NODE_ROLE='redpanda'; NODE_INDEX=1 ;;\n  10.0.83.12) NODE_NAME='redpanda-02'; NODE_ROLE='redpanda'; NODE_INDEX=2 ;;\n  10.0.83.13) NODE_NAME='redpanda-03'; NODE_ROLE='redpanda'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nREDPANDA_NODE_ID=$((NODE_INDEX - 1))\n\ninstall -d -m 0750 /opt/octastack/redpanda_native_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/redpanda_native_cluster_ha\ncat >/opt/octastack/redpanda_native_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=Redpanda\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.83.11\nCLUSTER_PEERS=10.0.83.11,10.0.83.12,10.0.83.13\nSEED_IPS=10.0.83.11,10.0.83.12,10.0.83.13\nREDPANDA_NODE_ID=$REDPANDA_NODE_ID\nREDPANDA_SEEDS=10.0.83.11:33145,10.0.83.12:33145,10.0.83.13:33145\nEOF\nchmod 0600 /opt/octastack/redpanda_native_cluster_ha/.env\n\ncat >/opt/octastack/redpanda_native_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  redpanda:\n    image: redpandadata/redpanda:v24.2.3\n    container_name: octastack-redpanda\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      redpanda start\n      --overprovisioned\n      --smp 1\n      --memory 2G\n      --reserve-memory 0M\n      --node-id=${REDPANDA_NODE_ID}\n      --check=false\n      --kafka-addr=internal://0.0.0.0:9092,external://0.0.0.0:19092\n      --advertise-kafka-addr=internal://${CURRENT_IP}:9092,external://${CURRENT_IP}:19092\n      --rpc-addr=0.0.0.0:33145\n      --advertise-rpc-addr=${CURRENT_IP}:33145\n      --seeds=${REDPANDA_SEEDS}\n    volumes:\n      - data:/var/lib/redpanda/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4410
          },
          "data": {
            "label": "Deploy Redpanda Native Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[redpanda_native_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/redpanda_native_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/redpanda_native_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/redpanda_native_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4815
