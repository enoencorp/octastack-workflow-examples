            "label": "Document Redpanda Native Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/redpanda_native_cluster_ha-topology.md <<'EOF'\n# Redpanda Native Cluster HA\n\nMembers:\n- redpanda-01: 10.0.83.11 (redpanda)\n- redpanda-02: 10.0.83.12 (redpanda)\n- redpanda-03: 10.0.83.13 (redpanda)\n\nThree Redpanda brokers run a native Raft-backed Kafka-compatible cluster with generated seed servers.\nEOF\ncat /tmp/redpanda_native_cluster_ha-topology.md\n",
            "sudo": true
          }
