        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 2295,
            "y": 3600
          },
          "data": {
            "label": "Render Prometheus Grafana HA installer",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/prometheus_grafana_ha\ncat >/opt/octastack/prometheus_grafana_ha/install.sh <<'OCTASTACK_INSTALLER'\nset -euo pipefail\n\nlog() { printf '[monitoring-ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.112.11 10.0.112.12 10.0.112.21 10.0.112.22 10.0.112.23 10.0.112.31 10.0.112.32 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.112.11) NODE_NAME='prometheus-01'; NODE_ROLE='prometheus'; NODE_INDEX=1 ;;\n  10.0.112.12) NODE_NAME='prometheus-02'; NODE_ROLE='prometheus'; NODE_INDEX=2 ;;\n  10.0.112.21) NODE_NAME='alertmanager-01'; NODE_ROLE='alertmanager'; NODE_INDEX=3 ;;\n  10.0.112.22) NODE_NAME='alertmanager-02'; NODE_ROLE='alertmanager'; NODE_INDEX=4 ;;\n  10.0.112.23) NODE_NAME='alertmanager-03'; NODE_ROLE='alertmanager'; NODE_INDEX=5 ;;\n  10.0.112.31) NODE_NAME='grafana-01'; NODE_ROLE='grafana'; NODE_INDEX=6 ;;\n  10.0.112.32) NODE_NAME='grafana-02'; NODE_ROLE='grafana'; NODE_INDEX=7 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\napt-get update\nif [ \"$NODE_ROLE\" = \"prometheus\" ]; then\n  log \"installing Prometheus node\"\n  DEBIAN_FRONTEND=noninteractive apt-get install -y prometheus prometheus-node-exporter\n  systemctl restart prometheus prometheus-node-exporter\n  systemctl enable prometheus prometheus-node-exporter\nelif [ \"$NODE_ROLE\" = \"alertmanager\" ]; then\n  log \"installing Alertmanager node\"\n  DEBIAN_FRONTEND=noninteractive apt-get install -y prometheus-alertmanager\n  install -d -m 0755 /etc/prometheus\n  cat >/etc/prometheus/alertmanager.yml <<'EOF'\nglobal:\n  resolve_timeout: 5m\nroute:\n  receiver: default\nreceivers:\n  - name: default\nEOF\n  systemctl restart prometheus-alertmanager\n  systemctl enable prometheus-alertmanager\nelif [ \"$NODE_ROLE\" = \"grafana\" ]; then\n  log \"installing Grafana node\"\n  DEBIAN_FRONTEND=noninteractive apt-get install -y grafana\n  systemctl restart grafana-server\n  systemctl enable grafana-server\nelse\n  log \"no monitoring action for role $NODE_ROLE\"\nfi\n\nOCTASTACK_INSTALLER\nchmod 0750 /opt/octastack/prometheus_grafana_ha/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 2295,
