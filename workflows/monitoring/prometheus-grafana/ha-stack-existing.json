          "data": {
            "label": "Review Prometheus Grafana HA installer",
            "command": "set -euo pipefail\nbash -n /opt/octastack/prometheus_grafana_ha/install.sh\nwc -l /opt/octastack/prometheus_grafana_ha/install.sh\nsed -n '1,120p' /opt/octastack/prometheus_grafana_ha/install.sh\n",
            "sudo": true
          }
