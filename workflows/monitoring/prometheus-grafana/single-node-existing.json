        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Render Prometheus Grafana single-node installer",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/prometheus_grafana_single_node\ncat >/opt/octastack/prometheus_grafana_single_node/install.sh <<'OCTASTACK_INSTALLER'\nset -euo pipefail\nsudo apt-get update\nsudo apt-get install -y prometheus prometheus-node-exporter grafana\nsudo systemctl enable --now prometheus prometheus-node-exporter grafana-server\nsudo tee /etc/prometheus/rules/octastack.rules.yml >/dev/null <<'EOF'\ngroups:\n  - name: octastack-base\n    rules:\n      - alert: InstanceDown\n        expr: up == 0\n        for: 2m\n        labels:\n          severity: critical\nEOF\nsudo systemctl restart prometheus\n\nOCTASTACK_INSTALLER\nchmod 0750 /opt/octastack/prometheus_grafana_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Review Prometheus Grafana single-node installer",
            "command": "set -euo pipefail\nbash -n /opt/octastack/prometheus_grafana_single_node/install.sh\nwc -l /opt/octastack/prometheus_grafana_single_node/install.sh\nsed -n '1,120p' /opt/octastack/prometheus_grafana_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Execute Prometheus Grafana single-node installer",
            "command": "set -euo pipefail\n/opt/octastack/prometheus_grafana_single_node/install.sh\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Collect Prometheus Grafana single-node runtime status",
            "command": "set -euo pipefail\nsystemctl --failed --no-pager || true\nif command -v docker >/dev/null 2>&1; then docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}' || true; fi\nif command -v kubectl >/dev/null 2>&1; then kubectl get nodes -o wide || true; kubectl get pods -A || true; fi\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Prometheus Grafana health check",
            "command": "curl -fsS http://127.0.0.1:9090/-/ready && curl -fsS http://127.0.0.1:3000/api/health",
            "sudo": false
          }
        },
