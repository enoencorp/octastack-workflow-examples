          "data": {
            "label": "Document HAProxy Active-Active Edge HA topology",
            "command": "set -euo pipefail\ncat >/tmp/haproxy_active_active_edge_ha-topology.md <<'EOF'\n# HAProxy Active-Active Edge HA\n\nMembers:\n- haproxy-01: 10.0.176.11 (load_balancer)\n- haproxy-02: 10.0.176.12 (load_balancer)\n\nTwo HAProxy nodes run the same edge configuration so upstream routing can fail over through external VIP, BGP, or DNS control.\nEOF\ncat /tmp/haproxy_active_active_edge_ha-topology.md\n",
            "sudo": true
          }
