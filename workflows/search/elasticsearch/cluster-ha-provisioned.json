        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Elasticsearch Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Render Elasticsearch Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[elasticsearch_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.129.11 10.0.129.12 10.0.129.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.129.11) NODE_NAME='elasticsearch-01'; NODE_ROLE='elasticsearch'; NODE_INDEX=1 ;;\n  10.0.129.12) NODE_NAME='elasticsearch-02'; NODE_ROLE='elasticsearch'; NODE_INDEX=2 ;;\n  10.0.129.13) NODE_NAME='elasticsearch-03'; NODE_ROLE='elasticsearch'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/elasticsearch_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/elasticsearch_cluster_ha\ncat >/opt/octastack/elasticsearch_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=Elasticsearch\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.129.11\nCLUSTER_PEERS=10.0.129.11,10.0.129.12,10.0.129.13\nSEED_IPS=10.0.129.11,10.0.129.12,10.0.129.13\n\nEOF\nchmod 0600 /opt/octastack/elasticsearch_cluster_ha/.env\n\ncat >/opt/octastack/elasticsearch_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  elasticsearch:\n    image: docker.elastic.co/elasticsearch/elasticsearch:8.15.0\n    container_name: octastack-elasticsearch\n    restart: unless-stopped\n    network_mode: host\n    ulimits:\n      memlock: -1\n    env_file:\n      - .env\n    environment:\n      cluster.name: \"octastack-elasticsearch\"\n      node.name: \"${OCTASTACK_NODE_NAME}\"\n      network.host: \"0.0.0.0\"\n      discovery.seed_hosts: \"10.0.129.11,10.0.129.12,10.0.129.13\"\n      cluster.initial_master_nodes: \"elasticsearch-01,elasticsearch-02,elasticsearch-03\"\n      xpack.security.enabled: \"false\"\n      ES_JAVA_OPTS: \"-Xms1g -Xmx1g\"\n      bootstrap.memory_lock: \"true\"\n    volumes:\n      - data:/usr/share/elasticsearch/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Deploy Elasticsearch Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[elasticsearch_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/elasticsearch_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/elasticsearch_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/elasticsearch_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Document Elasticsearch Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/elasticsearch_cluster_ha-topology.md <<'EOF'\n# Elasticsearch Cluster HA\n\nMembers:\n- elasticsearch-01: 10.0.129.11 (elasticsearch)\n- elasticsearch-02: 10.0.129.12 (elasticsearch)\n- elasticsearch-03: 10.0.129.13 (elasticsearch)\n\nThree Elasticsearch nodes form a discovery-backed cluster with generated initial master nodes and disabled demo security.\nEOF\ncat /tmp/elasticsearch_cluster_ha-topology.md\n",
            "sudo": true
          }
        },
