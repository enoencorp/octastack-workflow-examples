        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Meilisearch runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Meilisearch directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/meilisearch\ninstall -d -m 0750 /var/lib/octastack/meilisearch\ncat >/opt/octastack/meilisearch/.env <<'EOF'\nMEILI_MASTER_KEY=change-me\nEOF\nchmod 0600 /opt/octastack/meilisearch/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Meilisearch compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/meilisearch/compose.yml <<'COMPOSE'\nservices:\n  meilisearch:\n    image: getmeili/meilisearch:v1.10\n    container_name: octastack-meilisearch\n    restart: unless-stopped\n    environment:\n      MEILI_MASTER_KEY: \"change-me\"\n    ports:\n      - \"7700:7700\"\n    volumes:\n      - data:/meili_data\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Meilisearch",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/meilisearch/compose.yml pull\ndocker compose -f /opt/octastack/meilisearch/compose.yml up -d\ndocker compose -f /opt/octastack/meilisearch/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Meilisearch",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-meilisearch\ndocker logs octastack-meilisearch --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Meilisearch health check",
            "command": "curl -fsS http://127.0.0.1:7700/health",
            "sudo": false
          }
        },
        {
