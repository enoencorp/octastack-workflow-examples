        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Typesense Native Cluster HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Render Typesense Native Cluster HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[typesense_native_cluster_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.132.11 10.0.132.12 10.0.132.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.132.11) NODE_NAME='typesense-01'; NODE_ROLE='search'; NODE_INDEX=1 ;;\n  10.0.132.12) NODE_NAME='typesense-02'; NODE_ROLE='search'; NODE_INDEX=2 ;;\n  10.0.132.13) NODE_NAME='typesense-03'; NODE_ROLE='search'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/typesense_native_cluster_ha\ninstall -d -m 0750 /var/lib/octastack/typesense_native_cluster_ha\ncat >/opt/octastack/typesense_native_cluster_ha/.env <<EOF\nOCTASTACK_SERVICE=Typesense\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.132.11\nCLUSTER_PEERS=10.0.132.11,10.0.132.12,10.0.132.13\nSEED_IPS=10.0.132.11,10.0.132.12,10.0.132.13\n\nEOF\nchmod 0600 /opt/octastack/typesense_native_cluster_ha/.env\n\ncat >/opt/octastack/typesense_native_cluster_ha/nodes <<'EOF'\n10.0.132.11:8107:8108\n10.0.132.12:8107:8108\n10.0.132.13:8107:8108\nEOF\n\ncat >/opt/octastack/typesense_native_cluster_ha/compose.yml <<'COMPOSE'\nservices:\n  typesense:\n    image: typesense/typesense:27.1\n    container_name: octastack-typesense\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      --data-dir /data --api-key=change-me --enable-cors --peering-address ${CURRENT_IP} --peering-port 8107 --nodes=/data/nodes\n    volumes:\n      - data:/data\n      - /opt/octastack/typesense_native_cluster_ha/nodes:/data/nodes:ro\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Deploy Typesense Native Cluster HA node",
            "command": "set -euo pipefail\nlog() { printf '[typesense_native_cluster_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/typesense_native_cluster_ha/compose.yml pull\ndocker compose -f /opt/octastack/typesense_native_cluster_ha/compose.yml up -d\ndocker compose -f /opt/octastack/typesense_native_cluster_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Document Typesense Native Cluster HA topology",
            "command": "set -euo pipefail\ncat >/tmp/typesense_native_cluster_ha-topology.md <<'EOF'\n# Typesense Native Cluster HA\n\nMembers:\n- typesense-01: 10.0.132.11 (search)\n- typesense-02: 10.0.132.12 (search)\n- typesense-03: 10.0.132.13 (search)\n\nThree Typesense members run native clustering with a generated nodes file and per-node peering address.\nEOF\ncat /tmp/typesense_native_cluster_ha-topology.md\n",
            "sudo": true
          }
        },
