  "workflow": {
    "name": "Vault HA existing",
    "description": "Bootstrap and validate Vault HA from an existing automation runner and target inventory.",
    "graphData": {
      "nodes": [
        {
          "id": "node_trigger",
          "type": "triggerNode",
          "position": {
            "x": 45,
