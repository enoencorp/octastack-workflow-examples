        {
          "id": "node_wait_runner",
          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for automation runner",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Vault inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/vault-inventory.ini <<'INVENTORY'\n[vault]\n10.31.112.11 role=vault name=vault-01\n10.31.112.12 role=vault name=vault-02\n10.31.112.13 role=vault name=vault-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Install Vault container runtime",
            "command": "set -euo pipefail\ncat >/tmp/vault-runtime.yml <<'PLAYBOOK'\n- hosts: vault\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/vault-inventory.ini /tmp/vault-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Vault cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/vault-deploy.yml <<'PLAYBOOK'\n- hosts: vault\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/vault\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/vault/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            vault:\n              image: hashicorp/vault:1.17\n              container_name: octastack-vault\n              restart: unless-stopped\n              environment:\n                VAULT_DEV_ROOT_TOKEN_ID: \"change-me\"\n                VAULT_DEV_LISTEN_ADDRESS: \"0.0.0.0:8200\"\n              ports:\n                - \"8200:8200\"\n              volumes:\n                - data:/vault/file\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Vault cluster",
            "command": "set -euo pipefail\ncat >>/tmp/vault-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/vault/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/vault/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/vault/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/vault-inventory.ini /tmp/vault-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Document Vault topology",
            "command": "set -euo pipefail\ncat >/tmp/vault-topology.md <<'EOF'\n# Vault HA topology\n\nMembers:\n- vault-01: 10.31.112.11 (vault)\n- vault-02: 10.31.112.12 (vault)\n- vault-03: 10.31.112.13 (vault)\n\nThis example deploys one Vault container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/vault-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Validate Vault cluster",
            "command": "set -euo pipefail\nansible -i /tmp/vault-inventory.ini vault -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 5000
          },
          "data": {
            "label": "Vault HA health check",
            "command": "curl -fsS http://127.0.0.1:8200/v1/sys/health || true",
            "sudo": false
          }
        },
        {
