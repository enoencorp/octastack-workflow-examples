        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 3600
          },
          "data": {
            "label": "Prepare Vault Integrated Raft HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4005
          },
          "data": {
            "label": "Render Vault Integrated Raft HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[vault_integrated_raft_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.228.11 10.0.228.12 10.0.228.13 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.228.11) NODE_NAME='vault-01'; NODE_ROLE='vault'; NODE_INDEX=1 ;;\n  10.0.228.12) NODE_NAME='vault-02'; NODE_ROLE='vault'; NODE_INDEX=2 ;;\n  10.0.228.13) NODE_NAME='vault-03'; NODE_ROLE='vault'; NODE_INDEX=3 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/vault_integrated_raft_ha\ninstall -d -m 0750 /var/lib/octastack/vault_integrated_raft_ha\ncat >/opt/octastack/vault_integrated_raft_ha/.env <<EOF\nVAULT_DEV_ROOT_TOKEN_ID=change-me\nVAULT_DEV_LISTEN_ADDRESS=0.0.0.0:8200\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.228.11\nCLUSTER_PEERS=10.0.228.11,10.0.228.12,10.0.228.13\nSEED_IPS=10.0.228.11,10.0.228.12,10.0.228.13\n\nEOF\nchmod 0600 /opt/octastack/vault_integrated_raft_ha/.env\n\ncat >/opt/octastack/vault_integrated_raft_ha/vault.hcl <<HCL\nui = true\ndisable_mlock = false\nlistener \"tcp\" {\n  address = \"0.0.0.0:8200\"\n  tls_disable = true\n}\nstorage \"raft\" {\n  path = \"/vault/file\"\n  retry_join { leader_api_addr = \"http://10.0.228.11:8200\" }\n  retry_join { leader_api_addr = \"http://10.0.228.12:8200\" }\n  retry_join { leader_api_addr = \"http://10.0.228.13:8200\" }\n}\napi_addr = \"http://${CURRENT_IP}:8200\"\ncluster_addr = \"http://${CURRENT_IP}:8201\"\nHCL\n\ncat >/opt/octastack/vault_integrated_raft_ha/compose.yml <<'COMPOSE'\nservices:\n  vault:\n    image: hashicorp/vault:1.17\n    container_name: octastack-vault\n    restart: unless-stopped\n    network_mode: host\n    cap_add:\n      - IPC_LOCK\n    env_file:\n      - .env\n    environment:\n      VAULT_ADDR: \"http://127.0.0.1:8200\"\n    command: >\n      server -config=/vault/config/vault.hcl\n    volumes:\n      - data:/vault/file\n      - /opt/octastack/vault_integrated_raft_ha/vault.hcl:/vault/config/vault.hcl:ro\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4410
          },
          "data": {
            "label": "Deploy Vault Integrated Raft HA node",
            "command": "set -euo pipefail\nlog() { printf '[vault_integrated_raft_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/vault_integrated_raft_ha/compose.yml pull\ndocker compose -f /opt/octastack/vault_integrated_raft_ha/compose.yml up -d\ndocker compose -f /opt/octastack/vault_integrated_raft_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 885,
            "y": 4815
          },
          "data": {
            "label": "Document Vault Integrated Raft HA topology",
            "command": "set -euo pipefail\ncat >/tmp/vault_integrated_raft_ha-topology.md <<'EOF'\n# Vault Integrated Raft HA\n\nMembers:\n- vault-01: 10.0.228.11 (vault)\n- vault-02: 10.0.228.12 (vault)\n- vault-03: 10.0.228.13 (vault)\n\nThree Vault members use integrated Raft storage with generated retry_join stanzas and IPC_LOCK enabled.\nEOF\ncat /tmp/vault_integrated_raft_ha-topology.md\n",
            "sudo": true
          }
        },
