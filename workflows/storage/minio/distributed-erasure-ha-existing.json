        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1238,
            "y": 3600
          },
          "data": {
            "label": "Prepare MinIO Distributed Erasure Coding HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1238,
            "y": 4005
          },
          "data": {
            "label": "Render MinIO Distributed Erasure Coding HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[minio_distributed_erasure_coding_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.144.11 10.0.144.12 10.0.144.13 10.0.144.14 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.144.11) NODE_NAME='minio-01'; NODE_ROLE='minio'; NODE_INDEX=1 ;;\n  10.0.144.12) NODE_NAME='minio-02'; NODE_ROLE='minio'; NODE_INDEX=2 ;;\n  10.0.144.13) NODE_NAME='minio-03'; NODE_ROLE='minio'; NODE_INDEX=3 ;;\n  10.0.144.14) NODE_NAME='minio-04'; NODE_ROLE='minio'; NODE_INDEX=4 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\ninstall -d -m 0750 /opt/octastack/minio_distributed_erasure_coding_ha\ninstall -d -m 0750 /var/lib/octastack/minio_distributed_erasure_coding_ha\ncat >/opt/octastack/minio_distributed_erasure_coding_ha/.env <<EOF\nMINIO_ROOT_USER=admin\nMINIO_ROOT_PASSWORD=change-me-123456\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.144.11\nCLUSTER_PEERS=10.0.144.11,10.0.144.12,10.0.144.13,10.0.144.14\nSEED_IPS=10.0.144.11,10.0.144.12,10.0.144.13\n\nEOF\nchmod 0600 /opt/octastack/minio_distributed_erasure_coding_ha/.env\n\ncat >/opt/octastack/minio_distributed_erasure_coding_ha/compose.yml <<'COMPOSE'\nservices:\n  minio:\n    image: minio/minio:RELEASE.2024-08-29T01-40-52Z\n    container_name: octastack-minio\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      server --console-address ':9001' http://10.0.144.11:9000/data http://10.0.144.12:9000/data http://10.0.144.13:9000/data http://10.0.144.14:9000/data\n    volumes:\n      - data:/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1238,
