          },
          "data": {
            "label": "Document MinIO Distributed Erasure Coding HA topology",
            "command": "set -euo pipefail\ncat >/tmp/minio_distributed_erasure_coding_ha-topology.md <<'EOF'\n# MinIO Distributed Erasure Coding HA\n\nMembers:\n- minio-01: 10.0.144.11 (minio)\n- minio-02: 10.0.144.12 (minio)\n- minio-03: 10.0.144.13 (minio)\n- minio-04: 10.0.144.14 (minio)\n\nFour MinIO members run distributed erasure coding with a generated endpoint list and shared root credentials.\nEOF\ncat /tmp/minio_distributed_erasure_coding_ha-topology.md\n",
            "sudo": true
          }
        },
