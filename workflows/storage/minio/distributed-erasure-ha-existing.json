            "label": "Deploy MinIO Distributed Erasure Coding HA node",
            "command": "set -euo pipefail\nlog() { printf '[minio_distributed_erasure_coding_ha] %s\\n' \"$*\"; }\ndocker compose -f /opt/octastack/minio_distributed_erasure_coding_ha/compose.yml pull\ndocker compose -f /opt/octastack/minio_distributed_erasure_coding_ha/compose.yml up -d\ndocker compose -f /opt/octastack/minio_distributed_erasure_coding_ha/compose.yml ps\n      log \"node deployment complete\"\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
