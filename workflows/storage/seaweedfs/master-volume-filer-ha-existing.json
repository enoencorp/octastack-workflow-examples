          "data": {
            "label": "Document SeaweedFS Master Volume Filer HA topology",
            "command": "set -euo pipefail\ncat >/tmp/seaweedfs_master_volume_filer_ha-topology.md <<'EOF'\n# SeaweedFS Master Volume Filer HA\n\nMembers:\n- seaweed-master-01: 10.0.145.11 (master)\n- seaweed-master-02: 10.0.145.12 (master)\n- seaweed-master-03: 10.0.145.13 (master)\n- seaweed-volume-01: 10.0.145.21 (volume)\n- seaweed-volume-02: 10.0.145.22 (volume)\n- seaweed-filer-01: 10.0.145.31 (filer)\n- seaweed-filer-02: 10.0.145.32 (filer)\n\nSeaweedFS runs three master nodes plus replicated volume and filer nodes with generated master peer addresses.\nEOF\ncat /tmp/seaweedfs_master_volume_filer_ha-topology.md\n",
            "sudo": true
          }
