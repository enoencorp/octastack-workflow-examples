        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 3150,
            "y": 5000
          },
          "data": {
            "label": "Prepare SeaweedFS Master Volume Filer HA node runtime",
            "command": "set -euo pipefail\nlog() { printf '[container-runtime] %s\\n' \"$*\"; }\nif command -v docker >/dev/null 2>&1; then\n  log \"docker is already installed\"\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  log \"installing docker with apt\"\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  log \"installing docker with dnf\"\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  log \"installing docker with yum\"\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 3150,
            "y": 5405
          },
          "data": {
            "label": "Render SeaweedFS Master Volume Filer HA node configuration",
            "command": "set -euo pipefail\n\nlog() { printf '[seaweedfs_master_volume_filer_ha] %s\\n' \"$*\"; }\ndetect_current_ip() {\n  for candidate in $(hostname -I 2>/dev/null); do\n    case \" 10.0.145.11 10.0.145.12 10.0.145.13 10.0.145.21 10.0.145.22 10.0.145.31 10.0.145.32 \" in\n      *\" $candidate \"*) printf '%s' \"$candidate\"; return 0 ;;\n    esac\n  done\n  ip -o -4 addr show scope global 2>/dev/null | awk '{split($4,a,\"/\"); print a[1]; exit}'\n}\nCURRENT_IP=\"${OCTASTACK_NODE_IP:-$(detect_current_ip)}\"\nNODE_NAME=\"$(hostname -s)\"\nNODE_ROLE=\"unknown\"\nNODE_INDEX=0\ncase \"$CURRENT_IP\" in\n  10.0.145.11) NODE_NAME='seaweed-master-01'; NODE_ROLE='master'; NODE_INDEX=1 ;;\n  10.0.145.12) NODE_NAME='seaweed-master-02'; NODE_ROLE='master'; NODE_INDEX=2 ;;\n  10.0.145.13) NODE_NAME='seaweed-master-03'; NODE_ROLE='master'; NODE_INDEX=3 ;;\n  10.0.145.21) NODE_NAME='seaweed-volume-01'; NODE_ROLE='volume'; NODE_INDEX=4 ;;\n  10.0.145.22) NODE_NAME='seaweed-volume-02'; NODE_ROLE='volume'; NODE_INDEX=5 ;;\n  10.0.145.31) NODE_NAME='seaweed-filer-01'; NODE_ROLE='filer'; NODE_INDEX=6 ;;\n  10.0.145.32) NODE_NAME='seaweed-filer-02'; NODE_ROLE='filer'; NODE_INDEX=7 ;;\nesac\nif [ \"$NODE_ROLE\" = \"unknown\" ]; then\n  log \"unable to match current host IP ($CURRENT_IP) to the generated topology\"\n  exit 1\nfi\nlog \"running on $NODE_NAME ($CURRENT_IP, role=$NODE_ROLE)\"\n\nROLE_IMAGE=\"\"\nROLE_COMMAND=\"\"\ncase \"$NODE_ROLE\" in\n  master) ROLE_IMAGE=\"chrislusf/seaweedfs:3.73\"; ROLE_COMMAND=\"master -ip=${CURRENT_IP} -port=9333 -mdir=/data/master -peers=10.0.145.11:9333,10.0.145.12:9333,10.0.145.13:9333\" ;;\n  volume) ROLE_IMAGE=\"chrislusf/seaweedfs:3.73\"; ROLE_COMMAND=\"volume -ip=${CURRENT_IP} -port=8080 -dir=/data/volume -mserver=10.0.145.11:9333,10.0.145.12:9333,10.0.145.13:9333\" ;;\n  filer) ROLE_IMAGE=\"chrislusf/seaweedfs:3.73\"; ROLE_COMMAND=\"filer -ip=${CURRENT_IP} -port=8888 -master=10.0.145.11:9333,10.0.145.12:9333,10.0.145.13:9333\" ;;\n  *) log \"unsupported role $NODE_ROLE\"; exit 1 ;;\nesac\n\ninstall -d -m 0750 /opt/octastack/seaweedfs_master_volume_filer_ha\ninstall -d -m 0750 /var/lib/octastack/seaweedfs_master_volume_filer_ha\ncat >/opt/octastack/seaweedfs_master_volume_filer_ha/.env <<EOF\nOCTASTACK_SERVICE=SeaweedFS\nOCTASTACK_NODE_NAME=$NODE_NAME\nOCTASTACK_NODE_ROLE=$NODE_ROLE\nOCTASTACK_NODE_INDEX=$NODE_INDEX\nCURRENT_IP=$CURRENT_IP\nFIRST_NODE_IP=10.0.145.11\nCLUSTER_PEERS=10.0.145.11,10.0.145.12,10.0.145.13,10.0.145.21,10.0.145.22,10.0.145.31,10.0.145.32\nSEED_IPS=10.0.145.11,10.0.145.12,10.0.145.13\nROLE_IMAGE=$ROLE_IMAGE\nROLE_COMMAND=$ROLE_COMMAND\n\nEOF\nchmod 0600 /opt/octastack/seaweedfs_master_volume_filer_ha/.env\n\ncat >/opt/octastack/seaweedfs_master_volume_filer_ha/compose.yml <<'COMPOSE'\nservices:\n  seaweedfs:\n    image: ${ROLE_IMAGE}\n    container_name: octastack-seaweedfs\n    restart: unless-stopped\n    network_mode: host\n    env_file:\n      - .env\n    command: >\n      ${ROLE_COMMAND}\n    volumes:\n      - data:/data\nvolumes:\n  data: {}\nCOMPOSE\nlog \"configuration rendered\"\n",
            "sudo": true
          }
        },
