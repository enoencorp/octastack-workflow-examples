        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare ChromaDB inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/chromadb-inventory.ini <<'INVENTORY'\n[chromadb]\n10.31.129.11 role=vector name=chromadb-01\n10.31.129.12 role=vector name=chromadb-02\n10.31.129.13 role=vector name=chromadb-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install ChromaDB container runtime",
            "command": "set -euo pipefail\ncat >/tmp/chromadb-runtime.yml <<'PLAYBOOK'\n- hosts: chromadb\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/chromadb-inventory.ini /tmp/chromadb-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render ChromaDB cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/chromadb-deploy.yml <<'PLAYBOOK'\n- hosts: chromadb\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/chromadb\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/chromadb/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            chromadb:\n              image: chromadb/chroma:0.5.5\n              container_name: octastack-chromadb\n              restart: unless-stopped\n              ports:\n                - \"8000:8000\"\n              volumes:\n                - data:/chroma/chroma\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy ChromaDB cluster",
            "command": "set -euo pipefail\ncat >>/tmp/chromadb-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/chromadb/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/chromadb/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/chromadb/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/chromadb-inventory.ini /tmp/chromadb-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document ChromaDB topology",
            "command": "set -euo pipefail\ncat >/tmp/chromadb-topology.md <<'EOF'\n# ChromaDB HA topology\n\nMembers:\n- chromadb-01: 10.31.129.11 (vector)\n- chromadb-02: 10.31.129.12 (vector)\n- chromadb-03: 10.31.129.13 (vector)\n\nThis example deploys one ChromaDB container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/chromadb-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate ChromaDB cluster",
            "command": "set -euo pipefail\nansible -i /tmp/chromadb-inventory.ini chromadb -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
