          "id": "node_wait",
          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for existing host",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Milvus runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Milvus directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/milvus\ninstall -d -m 0750 /var/lib/octastack/milvus\ncat >/opt/octastack/milvus/.env <<'EOF'\nOCTASTACK_SERVICE=Milvus\nEOF\nchmod 0600 /opt/octastack/milvus/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Milvus compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/milvus/compose.yml <<'COMPOSE'\nservices:\n  milvus:\n    image: milvusdb/milvus:v2.4.6\n    container_name: octastack-milvus\n    restart: unless-stopped\n    command: \"milvus run standalone\"\n    ports:\n      - \"19530:19530\"\n      - \"9091:9091\"\n    volumes:\n      - data:/var/lib/milvus\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Milvus",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/milvus/compose.yml pull\ndocker compose -f /opt/octastack/milvus/compose.yml up -d\ndocker compose -f /opt/octastack/milvus/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Milvus",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-milvus\ndocker logs octastack-milvus --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Milvus health check",
            "command": "curl -fsS http://127.0.0.1:9091/healthz",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 4730
          },
          "data": {
            "label": "End"
          }
        }
