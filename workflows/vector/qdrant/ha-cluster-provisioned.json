        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5000
          },
          "data": {
            "label": "Prepare Qdrant inventory",
            "command": "set -euo pipefail\napt-get update\nDEBIAN_FRONTEND=noninteractive apt-get install -y ansible sshpass\ncat >/tmp/qdrant-inventory.ini <<'INVENTORY'\n[qdrant]\n10.31.126.11 role=vector name=qdrant-01\n10.31.126.12 role=vector name=qdrant-02\n10.31.126.13 role=vector name=qdrant-03\nINVENTORY\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5405
          },
          "data": {
            "label": "Install Qdrant container runtime",
            "command": "set -euo pipefail\ncat >/tmp/qdrant-runtime.yml <<'PLAYBOOK'\n- hosts: qdrant\n  become: true\n  tasks:\n    - ansible.builtin.shell: |\n        if command -v docker >/dev/null 2>&1; then\n          docker --version\n          exit 0\n        fi\n        if command -v apt-get >/dev/null 2>&1; then\n          apt-get update\n          DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\n        elif command -v dnf >/dev/null 2>&1; then\n          dnf install -y docker docker-compose-plugin\n        elif command -v yum >/dev/null 2>&1; then\n          yum install -y docker docker-compose-plugin\n        fi\n        systemctl enable --now docker\nPLAYBOOK\nansible-playbook -i /tmp/qdrant-inventory.ini /tmp/qdrant-runtime.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 5810
          },
          "data": {
            "label": "Render Qdrant cluster manifests",
            "command": "set -euo pipefail\ncat >/tmp/qdrant-deploy.yml <<'PLAYBOOK'\n- hosts: qdrant\n  become: true\n  tasks:\n    - ansible.builtin.file:\n        path: /opt/octastack/qdrant\n        state: directory\n        mode: \"0750\"\n    - ansible.builtin.copy:\n        dest: /opt/octastack/qdrant/compose.yml\n        mode: \"0640\"\n        content: |\n          services:\n            qdrant:\n              image: qdrant/qdrant:v1.11.0\n              container_name: octastack-qdrant\n              restart: unless-stopped\n              ports:\n                - \"6333:6333\"\n                - \"6334:6334\"\n              volumes:\n                - data:/qdrant/storage\n          volumes:\n            data: {}\nPLAYBOOK\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6215
          },
          "data": {
            "label": "Deploy Qdrant cluster",
            "command": "set -euo pipefail\ncat >>/tmp/qdrant-deploy.yml <<'PLAYBOOK'\n    - ansible.builtin.shell: docker compose -f /opt/octastack/qdrant/compose.yml pull\n    - ansible.builtin.shell: docker compose -f /opt/octastack/qdrant/compose.yml up -d\n    - ansible.builtin.shell: docker compose -f /opt/octastack/qdrant/compose.yml ps\nPLAYBOOK\nansible-playbook -i /tmp/qdrant-inventory.ini /tmp/qdrant-deploy.yml\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 6620
          },
          "data": {
            "label": "Document Qdrant topology",
            "command": "set -euo pipefail\ncat >/tmp/qdrant-topology.md <<'EOF'\n# Qdrant HA topology\n\nMembers:\n- qdrant-01: 10.31.126.11 (vector)\n- qdrant-02: 10.31.126.12 (vector)\n- qdrant-03: 10.31.126.13 (vector)\n\nThis example deploys one Qdrant container per member host. Replace the placeholder commands with vendor-supported clustering, TLS, backup, and failover automation before production use.\nEOF\ncat /tmp/qdrant-topology.md\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_6",
          "type": "configCommandNode",
          "position": {
            "x": 1740,
            "y": 7025
          },
          "data": {
            "label": "Validate Qdrant cluster",
            "command": "set -euo pipefail\nansible -i /tmp/qdrant-inventory.ini qdrant -b -m shell -a 'docker ps --format \"{{.Names}} {{.Status}}\"'\n",
            "sudo": true
          }
        },
