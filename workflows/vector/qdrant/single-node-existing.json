        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Qdrant runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Qdrant directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/qdrant\ninstall -d -m 0750 /var/lib/octastack/qdrant\ncat >/opt/octastack/qdrant/.env <<'EOF'\nOCTASTACK_SERVICE=Qdrant\nEOF\nchmod 0600 /opt/octastack/qdrant/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Qdrant compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/qdrant/compose.yml <<'COMPOSE'\nservices:\n  qdrant:\n    image: qdrant/qdrant:v1.11.0\n    container_name: octastack-qdrant\n    restart: unless-stopped\n    ports:\n      - \"6333:6333\"\n      - \"6334:6334\"\n    volumes:\n      - data:/qdrant/storage\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Qdrant",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/qdrant/compose.yml pull\ndocker compose -f /opt/octastack/qdrant/compose.yml up -d\ndocker compose -f /opt/octastack/qdrant/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Qdrant",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-qdrant\ndocker logs octastack-qdrant --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Qdrant health check",
            "command": "curl -fsS http://127.0.0.1:6333/healthz",
            "sudo": false
          }
        },
        {
