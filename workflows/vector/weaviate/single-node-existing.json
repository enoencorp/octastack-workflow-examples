          "id": "node_wait",
          "type": "waitUntilUpNode",
          "position": {
            "x": 885,
            "y": 885
          },
          "data": {
            "label": "Wait for existing host",
            "timeout": "20",
            "interval": "10",
            "probes": [
              {
                "id": "probe-0",
                "type": "ssh",
                "host": "",
                "port": "22",
                "label": "SSH reachability"
              }
            ]
          }
        },
        {
          "id": "node_step_1",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2300
          },
          "data": {
            "label": "Prepare Weaviate runtime",
            "command": "set -euo pipefail\nif command -v docker >/dev/null 2>&1; then\n  docker --version\n  exit 0\nfi\nif command -v apt-get >/dev/null 2>&1; then\n  apt-get update\n  DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io docker-compose-plugin\nelif command -v dnf >/dev/null 2>&1; then\n  dnf install -y docker docker-compose-plugin\nelif command -v yum >/dev/null 2>&1; then\n  yum install -y docker docker-compose-plugin\nelse\n  echo \"Unsupported package manager. Install Docker manually.\" >&2\n  exit 1\nfi\nsystemctl enable --now docker\ndocker version\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_2",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 2705
          },
          "data": {
            "label": "Create Weaviate directories",
            "command": "set -euo pipefail\ninstall -d -m 0750 /opt/octastack/weaviate\ninstall -d -m 0750 /var/lib/octastack/weaviate\ncat >/opt/octastack/weaviate/.env <<'EOF'\nQUERY_DEFAULTS_LIMIT=25\nAUTHENTICATION_ANONYMOUS_ACCESS_ENABLED=true\nPERSISTENCE_DATA_PATH=/var/lib/weaviate\nDEFAULT_VECTORIZER_MODULE=none\nCLUSTER_HOSTNAME=node1\nEOF\nchmod 0600 /opt/octastack/weaviate/.env\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_3",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3110
          },
          "data": {
            "label": "Render Weaviate compose",
            "command": "set -euo pipefail\ncat >/opt/octastack/weaviate/compose.yml <<'COMPOSE'\nservices:\n  weaviate:\n    image: semitechnologies/weaviate:1.26.1\n    container_name: octastack-weaviate\n    restart: unless-stopped\n    environment:\n      QUERY_DEFAULTS_LIMIT: \"25\"\n      AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED: \"true\"\n      PERSISTENCE_DATA_PATH: \"/var/lib/weaviate\"\n      DEFAULT_VECTORIZER_MODULE: \"none\"\n      CLUSTER_HOSTNAME: \"node1\"\n    ports:\n      - \"8080:8080\"\n    volumes:\n      - data:/var/lib/weaviate\nvolumes:\n  data: {}\nCOMPOSE\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_4",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3515
          },
          "data": {
            "label": "Deploy Weaviate",
            "command": "set -euo pipefail\ndocker compose -f /opt/octastack/weaviate/compose.yml pull\ndocker compose -f /opt/octastack/weaviate/compose.yml up -d\ndocker compose -f /opt/octastack/weaviate/compose.yml ps\n",
            "sudo": true
          }
        },
        {
          "id": "node_step_5",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 3920
          },
          "data": {
            "label": "Inspect Weaviate",
            "command": "set -euo pipefail\ndocker ps --filter name=octastack-weaviate\ndocker logs octastack-weaviate --tail=80 || true\n",
            "sudo": true
          }
        },
        {
          "id": "node_health",
          "type": "configCommandNode",
          "position": {
            "x": 180,
            "y": 4325
          },
          "data": {
            "label": "Weaviate health check",
            "command": "curl -fsS http://127.0.0.1:8080/v1/.well-known/ready",
            "sudo": false
          }
        },
        {
          "id": "node_end",
          "type": "endNode",
          "position": {
            "x": 230,
            "y": 4730
          },
          "data": {
            "label": "End"
          }
        }
